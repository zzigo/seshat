---
import Shell from '../components/Shell.astro';
const account=(Astro.locals as any).account;
if(!account)return Astro.redirect('/login');
if(account.status==='approved')return Astro.redirect(account.onboardingCompleted?'/dashboard':`/${account.locale||'en'}/welcome`);
const suspended=Astro.url.searchParams.get('state')==='suspended'||account.status==='suspended';
---
<Shell title="Account review — Seshat"><section class="pending"><div class="eyebrow">{suspended?'Account paused':'Application received'}</div><h1>{suspended?'Your Seshat access is paused.':'Your reading room is being prepared.'}</h1><p>{suspended?'Contact the Seshat administrator if you believe this is an error.':'Your choices are saved. You will be able to enter as soon as an administrator approves the account.'}</p><a href={`/${account.locale||'en'}/welcome`}>Review setup</a></section></Shell>
<style>.pending{max-width:820px;min-height:70vh;padding:16vh 0}.pending h1{font:400 clamp(48px,8vw,96px)/.98 Georgia,serif;margin:18px 0 30px}.pending p{max-width:620px;font:18px/1.6 Georgia,serif;color:var(--muted);margin-bottom:30px}</style>
