---
import { evaluateReferenceHealth, type BibliographicItem } from '@seshat/core';
import Shell from '../components/Shell.astro';
import { getCatalog, ownerKeyFor } from '../lib/catalog';

const sample: BibliographicItem = {
  id: 'demo:seshat',
  citeKey: 'clarke2005ways',
  type: 'book',
  title: 'Ways of Listening',
  contributors: [{ family: 'Clarke', given: 'Eric', role: 'author' }],
  issued: { year: 2005 },
  publisher: 'Oxford University Press',
  identifiers: { isbn: ['9780195151947'] },
  tags: ['listening', 'ecology'],
  source: {
    provider: 'zotero',
    libraryId: 'demo',
    itemKey: 'CLARKE05',
    version: 7,
    importedAt: new Date().toISOString(),
  },
  artifacts: [{
    id: 'demo:original',
    kind: 'original',
    storage: {
      provider: 'r2',
      objectKey: 'demo/clarke2005/original.pdf',
      mimeType: 'application/pdf',
    },
    createdAt: new Date().toISOString(),
  }],
  createdAt: '2026-06-30T00:00:00.000Z',
  updatedAt: '2026-06-30T00:00:00.000Z',
};
const report = evaluateReferenceHealth(sample);
const email = String((Astro.locals.session as any)?.user?.email || '');
const library = email
  ? await getCatalog().list(ownerKeyFor(email), 60).catch((error) => {
      console.error('[seshat:library]', error);
      return [];
    })
  : [];
const libraries = email ? await getCatalog().listLibraries(ownerKeyFor(email)).catch(() => []) : [];
const libraryNames = new Map(libraries.map((item) => [item.id, item.name]));
const stageLabel: Record<string, string> = {
  extract: 'extracting text',
  identify: 'identifying reference',
  summarize: 'writing summary',
  relate: 'relating corpus',
};
---

<Shell>
      {email && (
        <section class="library-home" id="library">
          <div class="section-heading library-heading">
            <div><div class="eyebrow">Your Seshat catalog</div><h2>The reading room</h2></div>
            <a class="button quiet" href="#drop">Drop anywhere</a>
          </div>
          <div class="library-shelves">
            {libraries.map((item) => <span><b>{item.name}</b>{item.itemCount} {item.itemCount === 1 ? 'item' : 'items'}</span>)}
          </div>
          {library.length ? (
            <div class="library-grid">
              {library.map((reference) => {
                const active = reference.jobs.find((job) => job.status === 'running' || job.status === 'queued')
                  ?? reference.jobs.find((job) => job.status === 'failed');
                const original = reference.artifacts.find((artifact) => artifact.kind === 'original');
                return (
                  <article class="library-card">
                    <div class="file-kind">{String((reference.source as any).originalFilename || 'document').split('.').pop()}</div>
                    <h3><a href={`/library/${reference.id}`}>{reference.title}</a></h3>
                    <p>@{reference.citeKey}</p>
                    <div class="card-libraries">{reference.libraryIds.map((id) => <span>{libraryNames.get(id) || 'Library'}</span>)}</div>
                    <div class="library-card-foot">
                      <span class:list={['catalog-state', active?.status]}>{active ? stageLabel[active.stage] || active.stage : 'catalogued'}</span>
                      {original && <a href={`/api/library/${reference.id}/original`} target="_blank">open original ↗</a>}
                    </div>
                  </article>
                );
              })}
            </div>
          ) : (
            <div class="library-empty"><span>𓅓</span><p>Your catalog is empty. Drop a document anywhere on this page.</p></div>
          )}
        </section>
      )}
      <section class="hero">
        <div class="eyebrow">An intelligent bibliography system</div>
        <h1>References should<br /><em>know what they contain.</em></h1>
        <p class="lede">
          Seshat keeps each citation connected to its document, structure,
          provenance and state of care—ready for humans, courses and local agents.
        </p>
        <div class="hero-actions">
          <a class="button primary" href="#specimen">Inspect a specimen</a>
          <a class="button quiet" href="/api/health.json">API health ↗</a>
        </div>
      </section>

      <section class="pipeline" aria-label="Seshat processing pipeline">
        <div class="pipeline-step"><b>01</b><span>Zotero / DOI / ISBN</span><small>collect</small></div>
        <i>→</i>
        <div class="pipeline-step"><b>02</b><span>R2 original</span><small>preserve</small></div>
        <i>→</i>
        <div class="pipeline-step"><b>03</b><span>Docling structure</span><small>understand</small></div>
        <i>→</i>
        <div class="pipeline-step"><b>04</b><span>Evidence graph</span><small>cultivate</small></div>
      </section>

      <section class="specimen" id="specimen">
        <div class="section-heading">
          <div>
            <div class="eyebrow">Live package output</div>
            <h2>A bibliographic specimen</h2>
          </div>
          <div class:list={['health-orbit', report.status]}>
            <strong>{report.score}</strong>
            <span>health</span>
          </div>
        </div>

        <article class="record-card">
          <div class="record-main">
            <div class="record-type">{sample.type}</div>
            <h3>{sample.title}</h3>
            <p>{sample.contributors[0].family}, {sample.contributors[0].given} · {sample.issued?.year}</p>
            <div class="tags">
              {sample.tags.map((tag) => <span>{tag}</span>)}
            </div>
          </div>
          <dl class="record-meta">
            <div><dt>Citekey</dt><dd>@{sample.citeKey}</dd></div>
            <div><dt>Fingerprint</dt><dd>{report.fingerprint}</dd></div>
            <div><dt>Source</dt><dd>Zotero · revision {sample.source.version}</dd></div>
            <div><dt>Original</dt><dd>Cloudflare R2 · linked</dd></div>
          </dl>
        </article>
      </section>

      <section class="principles">
        <article>
          <span>Ⅰ</span>
          <h3>Source-aware</h3>
          <p>Zotero is an adapter, not a prison. Stable identities survive migrations.</p>
        </article>
        <article>
          <span>Ⅱ</span>
          <h3>Evidence-first</h3>
          <p>Every chunk retains its page, heading, geometry, parser and original.</p>
        </article>
        <article>
          <span>Ⅲ</span>
          <h3>Actively curated</h3>
          <p>Metadata health becomes observable, explainable and eventually self-healing.</p>
        </article>
      </section>
      <div class="drop-hint" aria-hidden="true">Drop a document anywhere to begin</div>
</Shell>
