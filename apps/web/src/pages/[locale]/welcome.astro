---
import Shell from '../../components/Shell.astro';
import { ownerKeyFor, sessionIdentity } from '../../lib/catalog';
import { googleDriveStatus } from '../../lib/google-drive';
import { getZoteroConnectionStatus } from '../../lib/zotero-connection';

const locale=Astro.params.locale==='es'?'es':'en';
if(!['en','es'].includes(String(Astro.params.locale)))return Astro.redirect('/en/welcome');
const session=(Astro.locals as any).session;if(!session?.user?.email)return Astro.redirect(`/login?redirect=/${locale}/welcome`);
const account=(Astro.locals as any).account;const ownerKey=ownerKeyFor(sessionIdentity(session).email);
const [drive,zotero]=await Promise.all([googleDriveStatus(ownerKey),getZoteroConnectionStatus(ownerKey)]);
const t=locale==='es'?{
 title:'Prepará tu Seshat',kicker:'Una biblioteca propia, no otra nube',back:'Atrás',next:'Continuar',help:'¿Por qué?',skip:'Ahora no',
 institution:'¿Formás parte de alguna de estas instituciones?',institutionLead:'Sus estudiantes, docentes e investigadores pueden solicitar 10 GB administrados por Seshat.',independent:'Ninguna / independiente',email:'Correo institucional (para verificar)',
 byos:'¿Dónde querés que vivan tus documentos?',byosLead:'BYOS significa Bring Your Own Storage: el catálogo pertenece a Seshat, pero los archivos quedan en un espacio que vos controlás.',google:'Mi Google Drive',googleNote:'Privado, portable y con acceso limitado a la carpeta de Seshat.',managed:'10 GB institucionales',managedNote:'Disponible luego de confirmar tu vínculo con UNTREF o NMH.',
 root:'Elegí la raíz de tu archivo',rootLead:'Recomendamos una carpeta exclusiva. Todo lo que Seshat cree o vincule quedará organizado debajo de ella.',rootLabel:'Nombre de la carpeta raíz',connect:'Conectar Google Drive',connected:'Google Drive conectado',oauthMissing:'OAuth de Google Drive todavía no está configurado por el administrador.',
 zotero:'¿Querés vincular Zotero?',zoteroLead:'Es opcional. Seshat puede leer y escribir tu biblioteca sin copiar la estructura a otro lugar.',key:'Zotero API key',sync:'Dirección de sincronización',pull:'Solo traer',both:'Leer y escribir',
 finish:'Todo listo para solicitar acceso',finishLead:'Podés revisar las decisiones antes de enviar. La aprobación evita que una cuenta nueva alcance almacenamiento o datos privados.',submit:'Enviar solicitud',approved:'Entrar a Seshat',pending:'Solicitud enviada · esperando aprobación',
 h1:'La institución solo determina elegibilidad para la cuota administrada. La aprobación es manual.',h2:'Seshat guarda metadatos, relaciones y estado de lectura. BYOS mantiene los archivos en una cuenta bajo tu control.',h3:'La app solicita el permiso limitado drive.file: no puede recorrer todo tu Google Drive.',h4:'Creá una key personal en zotero.org/settings/keys. No se vuelve a mostrar: Seshat la cifra antes de guardarla.'
}:{
 title:'Prepare your Seshat',kicker:'Your library, not another cloud',back:'Back',next:'Continue',help:'Why?',skip:'Not now',
 institution:'Are you part of one of these institutions?',institutionLead:'Students, faculty and researchers may apply for 10 GB managed by Seshat.',independent:'None / independent',email:'Institutional email (for verification)',
 byos:'Where should your documents live?',byosLead:'BYOS means Bring Your Own Storage: Seshat owns the catalogue logic, while files remain in storage you control.',google:'My Google Drive',googleNote:'Private, portable, and limited to the Seshat folder.',managed:'Institutional 10 GB',managedNote:'Available after your UNTREF or NMH affiliation is confirmed.',
 root:'Choose the root of your archive',rootLead:'We recommend one dedicated folder. Everything Seshat creates or links stays organized beneath it.',rootLabel:'Root folder name',connect:'Connect Google Drive',connected:'Google Drive connected',oauthMissing:'Google Drive OAuth has not yet been configured by the administrator.',
 zotero:'Would you like to link Zotero?',zoteroLead:'Optional. Seshat can read and write your library without duplicating its hierarchy elsewhere.',key:'Zotero API key',sync:'Sync direction',pull:'Pull only',both:'Read and write',
 finish:'Ready to request access',finishLead:'Review your decisions before sending. Approval prevents a new account from reaching storage or private data.',submit:'Send application',approved:'Enter Seshat',pending:'Application sent · awaiting approval',
 h1:'Institution only determines eligibility for managed quota. Approval remains manual.',h2:'Seshat stores metadata, relations and reading state. BYOS keeps files in an account you control.',h3:'The app requests the limited drive.file scope and cannot browse your entire Google Drive.',h4:'Create a personal key at zotero.org/settings/keys. It is encrypted before Seshat stores it.'
};
const initial=JSON.stringify({locale,institution:account?.institution||'none',institutionEmail:account?.institutionEmail||'',quotaRequested:account?.quotaRequested||false,storageProvider:account?.storageProvider||'undecided',storageRootName:account?.storageRootName||'Seshat',step:account?.onboardingStep||0,status:account?.status||'pending',completed:account?.onboardingCompleted||false,drive,zotero}).replace(/</g,'\\u003c');
---
<Shell title={`${t.title} — Seshat`}>
<section class="welcome" data-locale={locale}>
  <header><div><div class="eyebrow">{t.kicker}</div><h1>{t.title}</h1></div><nav><a class:list={{active:locale==='es'}} href="/es/welcome">ES</a><a class:list={{active:locale==='en'}} href="/en/welcome">EN</a></nav></header>
  <div class="welcome-progress" aria-label="Onboarding progress"><i></i></div>
  <form class="welcome-flow">
    <fieldset data-step="0"><legend>{t.institution}</legend><p>{t.institutionLead}</p><div class="institution-options">
      <label class="institution-card"><input type="radio" name="institution" value="untref"/><span class="institution-logo untref" aria-label="UNTREF logo">UNTREF<small>Universidad Nacional<br/>de Tres de Febrero</small></span></label>
      <label class="institution-card"><input type="radio" name="institution" value="nmh"/><span class="institution-logo nmh" aria-label="Norwegian Academy of Music logo"><b>NMH</b><small>Norges musikkhøgskole<br/>Norwegian Academy of Music</small></span></label>
      <label class="institution-card independent"><input type="radio" name="institution" value="none"/><span>{t.independent}</span></label>
    </div><label class="institution-email" hidden>{t.email}<input type="email" name="institutionEmail" autocomplete="email"/></label><button type="button" class="text-help" data-help="h1">{t.help}</button></fieldset>
    <fieldset data-step="1"><legend>{t.byos}</legend><p>{t.byosLead}</p><div class="answer-options"><label><input type="radio" name="storageProvider" value="google-drive"/><span><b>{t.google}</b><small>{t.googleNote}</small></span></label><label data-managed><input type="radio" name="storageProvider" value="managed-wasabi"/><span><b>{t.managed}</b><small>{t.managedNote}</small></span></label></div><button type="button" class="text-help" data-help="h2">{t.help}</button></fieldset>
    <fieldset data-step="2" id="storage"><legend>{t.root}</legend><p>{t.rootLead}</p><label class="line-input">{t.rootLabel}<input type="text" name="storageRootName" value="Seshat" maxlength="100"/></label><div class="drive-action" data-drive hidden><a class="action-link" data-drive-connect>{drive.connected?t.connected:t.connect}</a><small>{!drive.configured?t.oauthMissing:drive.connected?`${drive.account} · ${drive.rootName}`:''}</small></div><button type="button" class="text-help" data-help="h3">{t.help}</button></fieldset>
    <fieldset data-step="3"><legend>{t.zotero}</legend><p>{t.zoteroLead}</p><label class="line-input">{t.key}<input type="password" name="zoteroKey" autocomplete="off" placeholder={zotero.connected?'••••••••••••••••':''}/></label><label class="line-input">{t.sync}<select name="syncMode"><option value="bidirectional">{t.both}</option><option value="pull">{t.pull}</option></select></label><button type="button" class="text-help" data-help="h4">{t.help}</button></fieldset>
    <fieldset data-step="4"><legend>{t.finish}</legend><p>{t.finishLead}</p><dl class="review"><div><dt>Institution</dt><dd data-review="institution"></dd></div><div><dt>Storage</dt><dd data-review="storage"></dd></div><div><dt>Root</dt><dd data-review="root"></dd></div><div><dt>Zotero</dt><dd>{zotero.connected?'connected':'optional'}</dd></div></dl></fieldset>
    <div class="flow-actions"><button type="button" data-back>{t.back}</button><button type="button" data-next>{t.next}</button></div><output role="status"></output>
  </form>
</section>
<dialog class="welcome-help"><button aria-label="Close">×</button><p></p></dialog>
<script is:inline type="application/json" id="welcome-data" set:html={initial}></script>
<script is:inline define:vars={{texts:{...t}}}>
  const state=JSON.parse(document.querySelector('#welcome-data').textContent);const form=document.querySelector('.welcome-flow');const fields=[...form.querySelectorAll('fieldset')];const back=form.querySelector('[data-back]');const next=form.querySelector('[data-next]');const output=form.querySelector('output');const progress=document.querySelector('.welcome-progress i');let step=Math.min(4,Math.max(0,state.step||0));
  const value=name=>form.elements[name]?.value||'';const radio=name=>form.querySelector(`input[name="${name}"]:checked`)?.value||'';
  const apply=()=>{fields.forEach((field,index)=>field.hidden=index!==step);back.hidden=step===0;next.textContent=step===4?(state.status==='approved'?texts.approved:texts.submit):texts.next;progress.style.width=`${(step+1)*20}%`;const institution=radio('institution')||state.institution;form.querySelector('.institution-email').hidden=institution==='none';form.querySelector('[data-managed]').hidden=institution==='none';form.querySelector('[data-drive]').hidden=(radio('storageProvider')||state.storageProvider)!=='google-drive';if(step===4){form.querySelector('[data-review="institution"]').textContent=institution==='none'?'Independent':institution.toUpperCase();form.querySelector('[data-review="storage"]').textContent=radio('storageProvider')||state.storageProvider;form.querySelector('[data-review="root"]').textContent=value('storageRootName');}};
  form.querySelectorAll('input[type="radio"]').forEach(input=>{if(input.value===state[input.name])input.checked=true;input.addEventListener('change',apply)});form.elements.institutionEmail.value=state.institutionEmail||'';form.elements.storageRootName.value=state.storageRootName||'Seshat';
  const save=async(completed=false)=>{const body={locale:state.locale,institution:radio('institution')||'none',institutionEmail:value('institutionEmail'),quotaRequested:(radio('institution')||'none')!=='none',storageProvider:radio('storageProvider')||'undecided',storageRootName:value('storageRootName'),step,completed};const response=await fetch('/api/account/onboarding',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(body)});if(!response.ok)throw new Error('Could not save setup');return response.json();};
  next.addEventListener('click',async()=>{output.textContent='';if(step===0&&!radio('institution')){output.textContent='Choose one option.';return}if(step===1&&!radio('storageProvider')){output.textContent='Choose one option.';return}next.disabled=true;try{if(step===3&&value('zoteroKey')){const response=await fetch('/api/zotero/connection',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({apiKey:value('zoteroKey'),syncMode:value('syncMode'),analyzeAutomatically:true,continuousSync:false,syncIntervalMinutes:60})});if(!response.ok){const result=await response.json().catch(()=>({}));throw new Error(result.error||'Zotero connection failed')}}if(step===4){await save(true);if(state.status==='approved')location.href='/dashboard';else location.href='/pending';return}step++;await save(false);apply()}catch(error){output.textContent=error.message||String(error)}finally{next.disabled=false}});back.addEventListener('click',()=>{if(step>0){step--;apply()}});
  const driveLink=form.querySelector('[data-drive-connect]');if(driveLink&&!state.drive.connected){if(state.drive.configured)driveLink.href=`/api/storage/google/connect?locale=${state.locale}&root=${encodeURIComponent(value('storageRootName'))}`;else{driveLink.setAttribute('aria-disabled','true');driveLink.addEventListener('click',event=>event.preventDefault())}}form.elements.storageRootName.addEventListener('input',()=>{if(driveLink&&state.drive.configured&&!state.drive.connected)driveLink.href=`/api/storage/google/connect?locale=${state.locale}&root=${encodeURIComponent(value('storageRootName'))}`});
  const dialog=document.querySelector('.welcome-help');document.querySelectorAll('[data-help]').forEach(button=>button.addEventListener('click',()=>{dialog.querySelector('p').textContent=texts[button.dataset.help];dialog.showModal()}));dialog.querySelector('button').addEventListener('click',()=>dialog.close());apply();
</script>
</Shell>
<style>
.welcome{max-width:1050px;margin:0 auto;padding:60px 0 110px;min-height:80vh}.welcome header{display:flex;justify-content:space-between;align-items:start}.welcome h1{font:400 clamp(46px,7vw,92px)/.95 Georgia,serif;margin:15px 0 26px}.welcome nav{display:flex;gap:12px;font-size:11px;letter-spacing:.12em}.welcome nav a:not(.active){opacity:.45}.welcome-progress{height:1px;background:color-mix(in srgb,var(--ink) 12%,transparent);margin:18px 0 9vh}.welcome-progress i{height:1px;display:block;background:var(--accent);transition:width .25s}.welcome-flow{max-width:860px}.welcome-flow fieldset{border:0;padding:0;margin:0;min-height:390px}.welcome-flow legend{font:400 clamp(34px,5vw,64px)/1.08 Georgia,serif;max-width:820px}.welcome-flow fieldset>p{font:18px/1.55 Georgia,serif;max-width:680px;color:var(--muted);margin:22px 0 38px}.institution-options,.answer-options{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:22px}.institution-card,.answer-options label{cursor:pointer;min-height:120px}.institution-card input,.answer-options input{position:absolute;opacity:0}.institution-logo,.institution-card>span,.answer-options label>span{display:flex;flex-direction:column;justify-content:center;gap:9px;height:100%;padding:18px 0;border-top:1px solid color-mix(in srgb,var(--ink) 18%,transparent);border-bottom:1px solid color-mix(in srgb,var(--ink) 18%,transparent)}.institution-card input:checked+span,.answer-options input:checked+span{border-color:var(--accent);color:var(--accent)}.institution-logo small,.answer-options small{font-size:11px;line-height:1.35;font-weight:400}.institution-logo.untref{font:bold 27px/1 Arial,sans-serif;letter-spacing:-.04em}.institution-logo.nmh{flex-direction:row;align-items:center;justify-content:start}.institution-logo.nmh b{font:700 30px/1 Arial,sans-serif}.independent{font:17px/1.3 Georgia,serif}.line-input,.institution-email{display:grid;gap:8px;max-width:620px;margin:25px 0;font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:var(--muted)}.line-input input,.line-input select,.institution-email input{border:0;border-bottom:1px solid color-mix(in srgb,var(--ink) 25%,transparent);background:transparent;color:var(--ink);font:18px/1.4 Georgia,serif;padding:10px 0;border-radius:0}.text-help,.flow-actions button{border:0;background:transparent;color:var(--ink);padding:8px 0;border-bottom:1px solid currentColor;cursor:pointer}.text-help{margin-top:24px;color:var(--muted)}.flow-actions{display:flex;justify-content:space-between;max-width:860px;margin-top:20px}.flow-actions [data-next]{color:var(--accent)}.welcome-flow output{display:block;color:#a84632;margin-top:18px}.drive-action{display:grid;gap:8px;margin-top:26px}.action-link{width:max-content;border-bottom:1px solid currentColor;cursor:pointer}.action-link[aria-disabled=true]{opacity:.45;cursor:not-allowed}.drive-action small{color:var(--muted)}.review{display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:25px}.review div{border-top:1px solid color-mix(in srgb,var(--ink) 18%,transparent);padding-top:13px}.review dt{font-size:10px;text-transform:uppercase;letter-spacing:.12em;color:var(--muted)}.review dd{font:20px/1.4 Georgia,serif;margin:5px 0}.welcome-help{max-width:480px;border:0;padding:40px;background:var(--paper);color:var(--ink);box-shadow:0 20px 80px #0004}.welcome-help::backdrop{background:#0007}.welcome-help button{position:absolute;right:14px;top:10px;border:0;background:transparent;color:inherit;font-size:25px}.welcome-help p{font:18px/1.55 Georgia,serif}@media(max-width:650px){.welcome{padding-top:40px}.welcome-progress{margin-bottom:8vh}.institution-options,.answer-options{grid-template-columns:1fr}.welcome-flow fieldset{min-height:440px}.institution-card,.answer-options label{min-height:78px}.review{grid-template-columns:1fr}}
</style>
