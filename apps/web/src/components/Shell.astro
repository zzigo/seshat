---
import { SignOut } from 'auth-astro/components';
import DropLayer from './DropLayer.astro';
import '../styles/global.css';
import { isSessionAccountAdmin } from '../lib/catalog';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Seshat — cultivate what you read',
  description = 'Seshat cultivates bibliographies that understand their documents.',
} = Astro.props;
const session = Astro.locals.session as any;
const account = Astro.locals.account as any;
const accountAdmin = isSessionAccountAdmin(session);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="Seshat" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="192x192" href="/favicon-192.png" />
    <title>{title}</title>
    <script is:inline>
      const theme = localStorage.getItem('seshat-theme') || 'light';
      const preset = localStorage.getItem('seshat-theme-preset') || localStorage.getItem(`seshat-theme-${theme}-preset`) || (theme === 'dark' ? 'ink' : 'papyrus');
      document.documentElement.setAttribute('data-theme', theme);
      document.documentElement.setAttribute('data-theme-preset', preset);
      document.documentElement.classList.toggle('dark-theme', theme === 'dark');
    </script>
  </head>
  <body>
    <header class="masthead">
      <a class="wordmark" href="/" aria-label="Seshat home">
        <span class="sigil" aria-hidden="true">𓋇</span>
        <span>Seshat</span>
      </a>
      <div class="identity">
        <button type="button" class="identity-action" data-toggle-theme style="border:0; background:transparent; font-size:14px; padding:0 8px; cursor:pointer;" title="Toggle dark/light theme">☼</button>
        {session?.user?.email ? (
          <>
            <a href="/dashboard#search" class="identity-action">search</a>
            <a href="/dashboard" class="identity-name">{session.user.name || session.user.email}</a>
            {account?.status === 'approved' && accountAdmin && <a href="/admin" class="identity-action">admin</a>}
            <SignOut><span class="identity-action">sign out</span></SignOut>
          </>
        ) : (
          <a class="identity-action" href="/login">sign in to cultivate</a>
        )}
      </div>
    </header>
    <main><slot /></main>
    <footer>
      <span>Seshat · House of Books</span>
      <span>writing / memory / measurement</span>
    </footer>
    <DropLayer authenticated={Boolean(session?.user?.email)} />
    <script>
      const themeBtn = document.querySelector('[data-toggle-theme]');
      themeBtn?.addEventListener('click', () => {
        const currentTheme = document.documentElement.getAttribute('data-theme') || 'light';
        const nextTheme = currentTheme === 'dark' ? 'light' : 'dark';
        const nextPreset = localStorage.getItem(`seshat-theme-${nextTheme}-preset`) || (nextTheme === 'dark' ? 'ink' : 'papyrus');
        document.documentElement.setAttribute('data-theme', nextTheme);
        document.documentElement.setAttribute('data-theme-preset', nextPreset);
        document.documentElement.classList.toggle('dark-theme', nextTheme === 'dark');
        localStorage.setItem('seshat-theme', nextTheme);
        localStorage.setItem('seshat-theme-preset', nextPreset);
        window.dispatchEvent(new CustomEvent('seshat:theme-changed', { detail: { theme: nextTheme, preset: nextPreset } }));
      });
    </script>
  </body>
</html>
