AUTH_URL=http://localhost:4331
AUTH_SECRET=replace-with-a-long-random-secret

# Primary Logto OIDC client. The generic OIDC keys below remain a migration fallback.
LOGTO_ISSUER_URL=https://your-logto.example/oidc
LOGTO_CLIENT_ID=
LOGTO_CLIENT_SECRET=
OIDC_ISSUER_URL=https://auth.musiki.org.ar/application/o/seshat/
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
SESHAT_ADMIN_EMAILS=
SESHAT_ADMIN_GROUPS=authentik Admins,Seshat Admins
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

DATABASE_URL=postgresql://user:password@127.0.0.1:5432/seshat
# Seshat uses Wasabi exclusively. Cloudflare R2 remains configured in Musiki only.
WASABI_ENDPOINT=https://s3.us-east-2.wasabisys.com
WASABI_REGION=us-east-2
WASABI_ACCESS_KEY_ID=
WASABI_SECRET_ACCESS_KEY=
WASABI_BUCKET=untref-licmusica
WASABI_KEY_PREFIX=zzttuntref
# These identities see WASABI_KEY_PREFIX/libros as their invisible storage root.
SESHAT_LIBRARY_ROOT_USERS=zztt,zzttuntref,lucianoazzigotti@gmail.com
GOOGLE_API_KEY=
GOOGLE_BOOKS_API_KEY=
GOOGLE_GENERATIVE_LANGUAGE_API_KEY=

# Google Chirp 3 HD server-side narration. Keep the JSON key outside the repo.
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GOOGLE_TTS_MONTHLY_CHARACTER_LIMIT=900000
GOOGLE_TTS_WARNING_CHARACTERS=700000
GOOGLE_TTS_ALLOWED_EMAILS=lucianoazzigotti@gmail.com,admin@musiki.org.ar

# Deterministic scholarly resolution and citation graph enrichment.
OPENALEX_API_BASE_URL=https://api.openalex.org
OPENALEX_API_KEY=
OPENALEX_MAILTO=
OPENALEX_TIMEOUT_MS=12000
OPENALEX_RETRIES=3
OPENALEX_CACHE_TTL_DAYS=30
OPENALEX_SHARED_TOPIC_THRESHOLD=0.25

# Trusted server-to-server consumers such as Musiki.
SESHAT_INTEGRATION_TOKEN=
# Optional fixed catalog for a trusted consumer deployment.
SESHAT_INTEGRATION_OWNER_KEY=

# Musiki directory used by Share Library magic search.
MUSIKI_API_URL=https://musiki.org.ar
