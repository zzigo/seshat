---
import { GetObjectCommand } from '@aws-sdk/client-s3';
import Shell from '../../components/Shell.astro';
import { getCatalog, ownerKeyFor } from '../../lib/catalog';
import { getR2Client } from '../../lib/r2';

const email = String((Astro.locals.session as any)?.user?.email || '');
const reference = await getCatalog().get(ownerKeyFor(email), Astro.params.id || '');
if (!reference) return new Response('Reference not found', { status: 404 });
const original = reference.artifacts.find((artifact) => artifact.kind === 'original');
const structureArtifact = reference.artifacts.find((artifact) => artifact.kind === 'structure');
type Section = { id: string; level: number; title: string; parentId?: string | null; sourceLine?: number };
let sections: Section[] = [];
if (structureArtifact?.bucket) {
  try {
    const object = await getR2Client().send(new GetObjectCommand({
      Bucket: structureArtifact.bucket,
      Key: structureArtifact.objectKey,
    }));
    const structure = JSON.parse(await object.Body!.transformToString()) as { sections?: Section[] };
    sections = (structure.sections || []).slice(0, 500);
  } catch (error) {
    console.error('[seshat:structure]', error);
  }
}
const authorName = (contributor: any): string => contributor.literal
  || [contributor.family, contributor.given].filter(Boolean).join(', ');
const authors = reference.contributors.map(authorName).filter(Boolean);
const year = String((reference.issued as any)?.year || '');
const isbns = (reference.identifiers.isbn as string[] | undefined) || [];
const labels: Record<string, string> = {
  extract: 'Extract text and structure',
  identify: 'Find ISBN, title and authors',
  summarize: 'Create an initial summary',
  relate: 'Relate tags to the corpus',
};

const ownerKey = ownerKeyFor(email);
const nodesResult = await getCatalog().pool.query(
  `SELECT node_key as id, kind, label, properties
   FROM catalog_graph_nodes
   WHERE owner_key = $1 AND node_key IN (
     SELECT DISTINCT from_key FROM catalog_graph_edges WHERE owner_key = $1 AND evidence_reference_id = $2
     UNION
     SELECT DISTINCT to_key FROM catalog_graph_edges WHERE owner_key = $1 AND evidence_reference_id = $2
   )`,
  [ownerKey, reference.id]
);
const edgesResult = await getCatalog().pool.query(
  `SELECT from_key as source, relation, to_key as target, weight
   FROM catalog_graph_edges
   WHERE owner_key = $1 AND evidence_reference_id = $2`,
  [ownerKey, reference.id]
);
const graphNodes = nodesResult.rows;
const graphEdges = edgesResult.rows;
---

<Shell title={`${reference.title} — Seshat`}>
  <section class="workspace-head compact record-head">
    <div class="eyebrow">Catalogued document</div>
    <h1 data-record-title>{reference.title}</h1>
    <p>The original is safe. Enrichment advances in explicit, inspectable stages.</p>
    {original && <a class="button quiet" href={`/api/library/${reference.id}/original`} target="_blank">Open original ↗</a>}
  </section>
  <section class="catalog-record">
    <div class="record-editor">
      <div class="panel-heading"><div><div class="eyebrow">Human curation</div><h2>Bibliographic record</h2></div><span>Manual fields are protected</span></div>
      <form class="metadata-form" data-metadata-form data-reference-id={reference.id}>
        <label><span>Title</span><input name="title" value={reference.title} maxlength="1000" required /></label>
        <input type="hidden" name="contributors" value={JSON.stringify(reference.contributors)} />
        <label><span>Contributors <small>edit structurally in Workspace</small></span><textarea rows="4" readonly>{authors.join('\n')}</textarea></label>
        <div class="metadata-pair">
          <label><span>Year</span><input name="year" value={year} inputmode="numeric" pattern="[0-9]{1,4}" /></label>
          <label><span>ISBN <small>one per line</small></span><textarea name="isbns" rows="3">{isbns.join('\n')}</textarea></label>
        </div>
        <div class="metadata-pair">
          <label><span>Type</span><select name="type">
            {['document','article','article-journal','book','chapter','paper-conference','report','thesis'].map((type) => <option value={type} selected={reference.type === type}>{type}</option>)}
          </select></label>
          <label><span>Citekey</span><input name="citeKey" value={reference.citeKey} maxlength="160" /></label>
        </div>
        <div class="metadata-pair">
          <label><span>Language</span><input name="language" value={reference.language || ''} maxlength="32" /></label>
          <label><span>Tags</span><input name="tags" value={reference.tags.join(', ')} /></label>
        </div>
        <div class="metadata-pair">
          <label><span>Publisher</span><input name="publisher" value={reference.publisher || ''} maxlength="500" /></label>
          <label><span>Place</span><input name="publisherPlace" value={reference.publisherPlace || ''} maxlength="500" /></label>
        </div>
        <label><span>URL</span><input name="url" value={reference.url || ''} maxlength="2000" /></label>
        <label><span>Abstract</span><textarea name="abstract" rows="5">{reference.abstract || ''}</textarea></label>
        <div class="metadata-actions">
          <button class="button primary" type="submit">Save record</button>
          <output data-form-status aria-live="polite"></output>
        </div>
      </form>
      <dl class="catalog-facts compact-facts">
        <div><dt>Citekey</dt><dd>@{reference.citeKey}</dd></div>
        <div><dt>SHA-256</dt><dd>{reference.originalSha256}</dd></div>
        <div><dt>Original</dt><dd>{original ? `${Math.round(original.sizeBytes / 1024)} KB · R2` : 'missing'}</dd></div>
      </dl>
    </div>
    <div>
      <div class="panel-heading"><div><div class="eyebrow">Enrichment</div><h2>Pipeline</h2></div></div>
      <div class="job-pipeline" data-reference-id={reference.id}>
        {reference.jobs.map((job, index) => (
          <button type="button" class:list={['job-card', job.status]} data-run-stage={job.stage} title={`Click to run/reprocess ${labels[job.stage] || job.stage}`}>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <div><strong>{labels[job.stage] || job.stage}</strong><small>{job.status}</small></div>
          </button>
        ))}
      </div>
    </div>
  </section>
  <section class="structure-panel">
    <div class="panel-heading">
      <div><div class="eyebrow">Docling structure</div><h2>Document map</h2></div>
      <span>{sections.length ? `${sections.length} sections` : structureArtifact ? 'No explicit headings' : 'Waiting for extraction'}</span>
    </div>
    {sections.length ? (
      <ol class="structure-list">
        {sections.map((section) => (
          <li style={`--indent:${Math.max(0, section.level - 1) * 24}px;--mobile-indent:${Math.max(0, Math.min(2, section.level - 1)) * 14}px`}>
            <span>{String(section.level).padStart(2, '0')}</span><strong>{section.title}</strong>
          </li>
        ))}
      </ol>
    ) : (
      <div class="structure-empty">The map will appear here as a durable derivative of the document.</div>
    )}
  </section>

  <section class="graph-panel">
    <div class="panel-heading">
      <div><div class="eyebrow">Relational evidence</div><h2>Knowledge graph</h2></div>
      <span>{graphNodes.length} nodes · {graphEdges.length} edges</span>
    </div>
    {graphNodes.length ? (
      <div class="graph-container">
        <svg id="kg-svg" viewBox="0 0 800 500" width="100%" height="500"></svg>
      </div>
    ) : (
      <div class="graph-empty">No entities or relationships have been extracted yet. Complete the relate pipeline stage to build the graph.</div>
    )}
  </section>

  <script is:inline define:vars={{ graphNodes, graphEdges }}>
    // Force-directed graph simulation
    const svg = document.getElementById('kg-svg');
    if (svg && graphNodes.length) {
      const width = 800;
      const height = 500;
      
      const nodes = graphNodes.map(n => ({
        ...n,
        x: width / 2 + (Math.random() - 0.5) * 200,
        y: height / 2 + (Math.random() - 0.5) * 200,
        vx: 0,
        vy: 0
      }));
      
      const nodeMap = new Map(nodes.map(n => [n.id, n]));
      const links = graphEdges.map(e => ({
        ...e,
        sourceNode: nodeMap.get(e.source),
        targetNode: nodeMap.get(e.target)
      })).filter(l => l.sourceNode && l.targetNode);

      const colors = {
        document: '#a855f7',
        person: '#3b82f6',
        concept: '#10b981',
        organization: '#f59e0b',
        place: '#ec4899',
        method: '#06b6d4',
        chunk: '#64748b'
      };

      svg.innerHTML = '';
      
      const defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');
      const marker = document.createElementNS('http://www.w3.org/2000/svg', 'marker');
      marker.setAttribute('id', 'arrow');
      marker.setAttribute('viewBox', '0 0 10 10');
      marker.setAttribute('refX', '18');
      marker.setAttribute('refY', '5');
      marker.setAttribute('markerWidth', '6');
      marker.setAttribute('markerHeight', '6');
      marker.setAttribute('orient', 'auto-start-reverse');
      const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
      path.setAttribute('d', 'M 0 0 L 10 5 L 0 10 z');
      path.setAttribute('fill', '#cbd5e1');
      marker.appendChild(path);
      defs.appendChild(marker);
      svg.appendChild(defs);

      const linkGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      svg.appendChild(linkGroup);
      const nodeGroup = document.createElementNS('http://www.w3.org/2000/svg', 'g');
      svg.appendChild(nodeGroup);

      const linkElements = links.map(link => {
        const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
        line.setAttribute('stroke', '#cbd5e1');
        line.setAttribute('stroke-width', '1.5');
        line.setAttribute('marker-end', 'url(#arrow)');
        linkGroup.appendChild(line);
        return { line, link };
      });

      const nodeElements = nodes.map(node => {
        const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');
        g.style.cursor = 'grab';

        const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');
        circle.setAttribute('r', node.kind === 'document' ? '12' : '8');
        circle.setAttribute('fill', colors[node.kind] || '#94a3b8');
        circle.setAttribute('stroke', '#ffffff');
        circle.setAttribute('stroke-width', '2');
        g.appendChild(circle);

        const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');
        text.textContent = node.label;
        text.setAttribute('dx', '14');
        text.setAttribute('dy', '4');
        text.setAttribute('font-size', '11px');
        text.setAttribute('fill', '#334155');
        text.setAttribute('font-weight', '500');
        text.setAttribute('font-family', 'system-ui, sans-serif');
        g.appendChild(text);

        nodeGroup.appendChild(g);
        return { g, node };
      });

      const iterations = 100;
      const k = 0.06;
      const rep = 500;
      
      for (let it = 0; it < iterations; it++) {
        for (let i = 0; i < nodes.length; i++) {
          for (let j = i + 1; j < nodes.length; j++) {
            const n1 = nodes[i];
            const n2 = nodes[j];
            const dx = n2.x - n1.x;
            const dy = n2.y - n1.y;
            const dist = Math.sqrt(dx * dx + dy * dy) || 1;
            if (dist < 300) {
              const force = rep / (dist * dist);
              const fx = (dx / dist) * force;
              const fy = (dy / dist) * force;
              n1.vx -= fx;
              n1.vy -= fy;
              n2.vx += fx;
              n2.vy += fy;
            }
          }
        }

        for (const link of links) {
          const n1 = link.sourceNode;
          const n2 = link.targetNode;
          const dx = n2.x - n1.x;
          const dy = n2.y - n1.y;
          const dist = Math.sqrt(dx * dx + dy * dy) || 1;
          const restLen = 80;
          const force = k * (dist - restLen);
          const fx = (dx / dist) * force;
          const fy = (dy / dist) * force;
          n1.vx += fx;
          n1.vy += fy;
          n2.vx -= fx;
          n2.vy -= fy;
        }

        for (const node of nodes) {
          const dx = width / 2 - node.x;
          const dy = height / 2 - node.y;
          node.vx += dx * 0.01;
          node.vy += dy * 0.01;

          node.x += node.vx;
          node.y += node.vy;

          node.vx *= 0.65;
          node.vy *= 0.65;
        }
      }

      function updatePositions() {
        linkElements.forEach(({ line, link }) => {
          line.setAttribute('x1', link.sourceNode.x);
          line.setAttribute('y1', link.sourceNode.y);
          line.setAttribute('x2', link.targetNode.x);
          line.setAttribute('y2', link.targetNode.y);
        });
        nodeElements.forEach(({ g, node }) => {
          g.setAttribute('transform', `translate(${node.x}, ${node.y})`);
        });
      }
      updatePositions();

      let selectedNode = null;
      nodeElements.forEach(({ g, node }) => {
        g.addEventListener('mousedown', () => {
          selectedNode = node;
          g.style.cursor = 'grabbing';
        });
      });

      svg.addEventListener('mousemove', (e) => {
        if (selectedNode) {
          const rect = svg.getBoundingClientRect();
          selectedNode.x = ((e.clientX - rect.left) / rect.width) * width;
          selectedNode.y = ((e.clientY - rect.top) / rect.height) * height;
          updatePositions();
        }
      });

      window.addEventListener('mouseup', () => {
        if (selectedNode) {
          nodeElements.forEach(({ g }) => g.style.cursor = 'grab');
          selectedNode = null;
        }
      });
    }
  </script>

  <script>
    const form = document.querySelector<HTMLFormElement>('[data-metadata-form]');
    form?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const button = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const status = form.querySelector<HTMLOutputElement>('[data-form-status]');
      if (!button || !status) return;
      button.disabled = true;
      status.value = 'Saving…';
      try {
        const id = form.dataset.referenceId;
        const response = await fetch(`/api/library/${id}/metadata`, { method: 'POST', body: new FormData(form) });
        const result = await response.json();
        if (!response.ok) throw new Error(result.error || 'The record could not be saved.');
        const title = form.elements.namedItem('title') as HTMLInputElement;
        const heading = document.querySelector<HTMLElement>('[data-record-title]');
        if (heading) heading.textContent = title.value;
        status.value = 'Saved · protected from automatic overwrite';
      } catch (error) {
        status.value = error instanceof Error ? error.message : 'The record could not be saved.';
      } finally {
        button.disabled = false;
      }
    });

    // Click on job card to queue/reprocess
    document.querySelectorAll<HTMLButtonElement>('[data-run-stage]').forEach((btn) => {
      btn.addEventListener('click', async () => {
        const stage = btn.dataset.runStage;
        const refId = btn.parentElement?.dataset.referenceId;
        if (!stage || !refId) return;
        const small = btn.querySelector('small');
        if (small) small.textContent = 'queueing…';
        btn.disabled = true;
        try {
          const response = await fetch('/api/library/actions', {
            method: 'POST',
            headers: { 'content-type': 'application/json' },
            body: JSON.stringify({ ids: [refId], action: stage })
          });
          const result = await response.json();
          if (!response.ok) throw new Error(result.error || 'Failed to queue stage');
          if (small) small.textContent = 'queued';
          setTimeout(() => window.location.reload(), 500);
        } catch (error: any) {
          if (small) small.textContent = 'failed to queue';
          alert(error.message || 'Error queueing stage');
          btn.disabled = false;
        }
      });
    });
  </script>
</Shell>
