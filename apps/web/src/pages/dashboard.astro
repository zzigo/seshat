---
import Shell from '../components/Shell.astro';
import { getCatalog, isSessionAccountAdmin, ownerKeyFor, sessionIdentity } from '../lib/catalog';
import { chirpAccessAllowed } from '../lib/chirp-access';
import { chirpMonth, CHIRP_VOICES, DEFAULT_CHIRP_LIMIT, nextChirpRenewal } from '../lib/chirp';
import { getZoteroConnectionStatus } from '../lib/zotero-connection';

const session = (Astro.locals as any).session; const identity = sessionIdentity(session);
const catalog = getCatalog(); const stats = await catalog.dashboardStats(ownerKeyFor(identity.email));
const zoteroStatus = await getZoteroConnectionStatus(ownerKeyFor(identity.email));
const admin = isSessionAccountAdmin(session);
const linkedEmailsQuery = await catalog.pool.query(
  'SELECT DISTINCT current_email FROM catalog_identities WHERE owner_key = $1 ORDER BY current_email ASC',
  [ownerKeyFor(identity.email)]
);
const linkedEmails = linkedEmailsQuery.rows.map((row: any) => row.current_email).filter((email: string) => email.toLowerCase() !== identity.email.toLowerCase());
const chirpEnabled = chirpAccessAllowed(identity.email); const chirpLimit = Math.max(1,Number(process.env.GOOGLE_TTS_MONTHLY_CHARACTER_LIMIT || DEFAULT_CHIRP_LIMIT));
const chirpUsed = chirpEnabled ? await catalog.getTtsUsage('google-chirp-3-hd',chirpMonth()) : 0;
const years = stats.publicationYears; const width = 760; const height = 250; const padX = 42; const padY = 32;
const minYear = years[0]?.year || new Date().getFullYear(); const maxYear = years.at(-1)?.year || minYear;
const maxCount = Math.max(1, ...years.map((item) => item.count)); const span = Math.max(1, maxYear - minYear);
const point = (item: { year: number; count: number }) => ({
  x: padX + ((item.year - minYear) / span) * (width - padX * 2),
  y: height - padY - (item.count / maxCount) * (height - padY * 2),
});
const points = years.map(point); const line = points.map((item) => `${item.x},${item.y}`).join(' ');
const area = points.length ? `${padX},${height - padY} ${line} ${points.at(-1)!.x},${height - padY}` : '';
const number = (value: number) => new Intl.NumberFormat('en').format(value);
---

<Shell title="Dashboard — Seshat">
  <section class="account-dashboard">
    <header class="dashboard-head">
      <div><div class="eyebrow">Personal archive</div><h1>{session.user.name || identity.email}</h1><p>{identity.email}</p></div>
      <a class="button quiet" href="/workspace">Open workspace →</a>
    </header>

    <div class="dashboard-totals">
      <article><span>Items</span><strong>{number(stats.totals.items)}</strong></article>
      <article><span>Words extracted</span><strong>{number(stats.totals.words)}</strong></article>
      <article><span>Annotations</span><strong>{number(stats.totals.annotations)}</strong></article>
      <article><span>Libraries</span><strong>{number(stats.totals.libraries)}</strong></article>
      <article><span>OpenAlex concepts</span><strong>{number(stats.totals.concepts)}</strong></article>
    </div>

    <section class="dashboard-panel years-panel">
      <header>
        <div><span>Publication history</span><h2>Items by year</h2></div>
        <div class="years-head-tools">
          <small>{minYear === maxYear ? minYear : `${minYear}—${maxYear}`}</small>
          {years.length > 0 && <div class="years-controls" aria-label="Timeline controls">
            <button type="button" data-years-zoom-out aria-label="Zoom timeline out" title="Zoom out">
              <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10" /></svg>
            </button>
            <output data-years-zoom-label>100%</output>
            <button type="button" data-years-zoom-in aria-label="Zoom timeline in" title="Zoom in">
              <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10M8 3v10" /></svg>
            </button>
            <button type="button" data-years-zoom-reset aria-label="Fit timeline to panel" title="Fit timeline">
              <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M2.5 5V2.5H5M11 2.5h2.5V5M13.5 11v2.5H11M5 13.5H2.5V11" /></svg>
            </button>
            <button type="button" data-years-expand aria-label="Expand timeline" aria-pressed="false" title="Expand timeline">
              <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M2.5 6V2.5H6M10 2.5h3.5V6M13.5 10v3.5H10M6 13.5H2.5V10" /></svg>
            </button>
          </div>}
        </div>
      </header>
      {years.length ? (
        <div class="years-viewport" data-years-timeline>
          <svg data-years-svg viewBox={`0 0 ${width} ${height}`} role="img" aria-label="Publication items by year">
            {[0,.25,.5,.75,1].map((ratio) => <line data-grid-ratio={ratio} x1={padX} x2={width-padX} y1={padY + ratio*(height-padY*2)} y2={padY + ratio*(height-padY*2)} />)}
            <polygon data-years-area points={area} class="year-area" />
            <polyline data-years-line points={line} class="year-line" />
            {years.map((item) => { const p = point(item); return <g data-year-point data-year={item.year} data-count={item.count}><circle cx={p.x} cy={p.y} r="4"><title>{item.year}: {item.count}</title></circle><text x={p.x} y={height-8}>{item.year}</text></g>; })}
          </svg>
        </div>
      ) : <div class="dashboard-empty">No publication years yet.</div>}
    </section>

    <div class="dashboard-columns">
      <section class="dashboard-panel ranking-panel">
        <header><div><span>Corpus</span><h2>Top authors</h2></div><small>items</small></header>
        <ol>{stats.topAuthors.map((author) => <li><span>{author.name}</span><b>{author.count}</b></li>)}</ol>
        {!stats.topAuthors.length && <div class="dashboard-empty">No structured authors yet.</div>}
      </section>
      <section class="dashboard-panel ranking-panel tags-panel">
        <header><div><span>Vocabulary</span><h2>Top tags</h2></div><small>items</small></header>
        <div class="tag-cloud">{stats.topTags.map((tag) => <span style={`--weight:${Math.max(.72,Math.min(1.45,.72+tag.count*.1))}`}>{tag.name}<b>{tag.count}</b></span>)}</div>
        {!stats.topTags.length && <div class="dashboard-empty">No tags yet.</div>}
      </section>
    </div>

    <section class="dashboard-panel concepts-panel">
      <header><div><span>Knowledge graph</span><h2>Concept network</h2></div><small>connected items</small></header>
      <div class="concept-list">{stats.topConcepts.map((concept) => <span><i></i>{concept.name}<b>{concept.count}</b></span>)}</div>
      {!stats.topConcepts.length && <div class="dashboard-empty">Resolve papers with OpenAlex to discover concepts.</div>}
    </section>

    <section class="dashboard-panel zotero-panel" data-zotero-settings data-connected={String(zoteroStatus.connected)}>
      <header>
        <div><span>Bibliography bridge</span><h2>Zotero synchronization</h2></div>
        <small data-zotero-state>{zoteroStatus.connected ? `${zoteroStatus.username} · ${zoteroStatus.continuousSync === false ? 'connected' : 'continuous sync'}` : 'not connected'}</small>
      </header>
      <form data-zotero-form>
        <label class="zotero-key-field"><span>Zotero API key</span><input type="password" name="apiKey" autocomplete="off" placeholder={zoteroStatus.connected ? 'Leave blank to keep the stored key' : 'Paste a library API key'} /><small class="zotero-credential-state" data-zotero-credential data-stored={String(zoteroStatus.apiKeyStored)}>{zoteroStatus.apiKeyStored ? '● key stored encrypted on the server' : 'No key stored'}</small></label>
        <label><span>Direction</span><select name="syncMode">
          <option value="bidirectional" selected={zoteroStatus.syncMode === 'bidirectional' || !zoteroStatus.syncMode}>Bidirectional · read + write</option>
          <option value="pull" selected={zoteroStatus.syncMode === 'pull'}>Pull from Zotero</option>
          <option value="push" selected={zoteroStatus.syncMode === 'push'}>Push to Zotero</option>
        </select></label>
        <label class="zotero-analysis-check"><input type="checkbox" name="analyzeAutomatically" checked={zoteroStatus.analyzeAutomatically !== false} /><span><b>Analyze linked files automatically</b><small>Turn off before a massive first synchronization.</small></span></label>
        <div class="zotero-sync-schedule">
          <label class="zotero-continuous-check"><input type="checkbox" name="continuousSync" checked={zoteroStatus.continuousSync !== false} /><span><b>Continuous synchronization</b><small>The key remains encrypted on the server; this page does not need to stay open.</small></span></label>
          <label><span>Check Zotero every</span><select name="syncIntervalMinutes">
            {[5, 15, 30, 60].map((minutes) => <option value={minutes} selected={(zoteroStatus.syncIntervalMinutes || 15) === minutes}>{minutes} minutes</option>)}
          </select></label>
        </div>
        <div class="zotero-actions">
          <button class="button primary" type="submit">Test & save</button>
          <button class="button quiet" type="button" data-zotero-preview disabled={!zoteroStatus.connected}>Preview sync</button>
          <button class="button quiet" type="button" data-zotero-sync disabled>Sync now</button>
          <button class="button quiet" type="button" data-zotero-disconnect hidden={!zoteroStatus.connected}>Disconnect</button>
        </div>
        <output data-zotero-output aria-live="polite"></output>
      </form>
      <div class="zotero-contract">
        <div><span>Local scope</span><strong>Zotero/</strong><small>Only this metafolder participates in remote writes.</small></div>
        <div><span>Binary originals</span><strong>Wasabi</strong><small>Zotero sync changes metadata, collections and membership.</small></div>
        <div><span>Deletion policy</span><strong>Non-destructive</strong><small>No automatic remote or local deletions.</small></div>
        <div><span>Last synchronization</span><strong>{zoteroStatus.lastSyncedAt ? new Date(zoteroStatus.lastSyncedAt).toLocaleString() : 'Never'}</strong><small>{zoteroStatus.libraryVersion ? `library version ${zoteroStatus.libraryVersion}${zoteroStatus.lastCheckedAt ? ` · checked ${new Date(zoteroStatus.lastCheckedAt).toLocaleString()}` : ''}` : 'Preview required before first sync'}</small></div>
      </div>
      <div class="zotero-preview" data-zotero-preview-result hidden></div>
    </section>

    <section class="dashboard-panel voice-panel" data-voice-settings>
      <header><div><span>Reader</span><h2>Voice settings</h2></div><small data-voice-summary>loading installed voices…</small></header>
      <div class="voice-settings-body">
        <p>Select the browser and Microsoft voices shown in the Reader menu. With no selection, every installed voice remains visible.</p>
        <div class="voice-settings-tools">
          <label><span>Find installed voice</span><input type="search" data-voice-search placeholder="Name or language…" /></label>
          <button class="button quiet" type="button" data-microsoft-only>Microsoft only</button>
          <button class="button quiet" type="button" data-show-all>Show all</button>
        </div>
        <div class="voice-checklist" data-voice-list aria-live="polite"></div>
        {chirpEnabled && <div class="chirp-dashboard-settings">
          <div><span>Private cloud provider</span><strong>Google Chirp 3 HD</strong><small>{process.env.GOOGLE_CLOUD_PROJECT || 'not configured'}</small></div>
          <div><span>Monthly balance</span><strong>{number(Math.max(0,chirpLimit-chirpUsed))} / {number(chirpLimit)}</strong><small>renews {new Date(nextChirpRenewal()).toLocaleDateString()}</small></div>
          <label><span>Preferred Chirp voice</span><select data-chirp-voice><option value="">Automatic by item language</option>{CHIRP_VOICES.map((voice)=><option value={voice.id}>{voice.label}</option>)}</select></label>
        </div>}
      </div>
    </section>

    <section class="dashboard-panel account-panel">
      <header><div><span>Identity</span><h2>Logto account</h2></div><small>associated logins</small></header>
      <dl>
        <div><dt>Primary email</dt><dd>{identity.email}</dd></div>
        <div><dt>Linked emails</dt><dd>{linkedEmails.length ? linkedEmails.join(', ') : 'None linked'}</dd></div>
        <div><dt>Subject</dt><dd>{identity.subject ? `${identity.subject.slice(0,8)}…` : 'refresh login required'}</dd></div>
      </dl>

      <form data-associate-email>
        <label><span>Link secondary login email</span><input type="email" name="secondaryEmail" required placeholder="secondary@email.example" /></label>
        <button class="button primary" type="submit">Link login email</button>
        <output aria-live="polite"></output>
        <p>This allows you to log in with a second email/identity and access the same catalog workspace. Catalogs will merge if the email already has catalog items.</p>
      </form>

      {admin && (
        <form data-recover-catalog style="border-top:1px dashed var(--line); margin-top:16px; padding-top:16px;">
          <label><span>[Admin] Previous login email</span><input type="email" name="previousEmail" required placeholder="previous@email.example" /></label>
          <button class="button secondary" type="submit">Recover previous catalog</button>
          <output aria-live="polite"></output>
          <p>Administrative tool: links the stable identity to an unclaimed catalog and merges current items when no conflicts exist.</p>
        </form>
      )}
    </section>
  </section>

  <script>
    const yearsTimeline=document.querySelector<HTMLElement>('[data-years-timeline]');
    if(yearsTimeline){
      const panel=yearsTimeline.closest<HTMLElement>('.years-panel')!;
      const svg=yearsTimeline.querySelector<SVGSVGElement>('[data-years-svg]')!;
      const area=svg.querySelector<SVGPolygonElement>('[data-years-area]')!;
      const line=svg.querySelector<SVGPolylineElement>('[data-years-line]')!;
      const grids=[...svg.querySelectorAll<SVGLineElement>('[data-grid-ratio]')];
      const nodes=[...svg.querySelectorAll<SVGGElement>('[data-year-point]')].map((group)=>({group,year:Number(group.dataset.year),count:Number(group.dataset.count),circle:group.querySelector<SVGCircleElement>('circle')!,label:group.querySelector<SVGTextElement>('text')!}));
      const zoomLabel=panel.querySelector<HTMLOutputElement>('[data-years-zoom-label]')!;
      const expandButton=panel.querySelector<HTMLButtonElement>('[data-years-expand]')!;
      const minYear=Math.min(...nodes.map((node)=>node.year));const maxYear=Math.max(...nodes.map((node)=>node.year));const maxCount=Math.max(1,...nodes.map((node)=>node.count));const yearSpan=Math.max(1,maxYear-minYear);
      const padX=42;const padY=32;let zoom=1;let expanded=false;
      const clamp=(value:number,min:number,max:number)=>Math.max(min,Math.min(max,value));
      const niceStep=(minimum:number)=>{const power=10**Math.floor(Math.log10(Math.max(1,minimum)));const fraction=minimum/power;return (fraction<=1?1:fraction<=2?2:fraction<=5?5:10)*power;};
      const renderTimeline=()=>{
        const chartWidth=Math.max(320,Math.round(yearsTimeline.clientWidth*Math.max(1,zoom)));
        const chartHeight=expanded?Math.max(250,Math.round(yearsTimeline.clientHeight)):250;
        const innerWidth=Math.max(1,chartWidth-padX*2);const innerHeight=Math.max(1,chartHeight-padY*2);
        svg.setAttribute('viewBox',`0 0 ${chartWidth} ${chartHeight}`);svg.style.width=`${chartWidth}px`;svg.style.height=`${chartHeight}px`;
        grids.forEach((grid)=>{const ratio=Number(grid.dataset.gridRatio);const y=padY+ratio*innerHeight;grid.setAttribute('x1',String(padX));grid.setAttribute('x2',String(chartWidth-padX));grid.setAttribute('y1',String(y));grid.setAttribute('y2',String(y));});
        const plotted=nodes.map((node)=>{const x=minYear===maxYear?chartWidth/2:padX+((node.year-minYear)/yearSpan)*innerWidth;const y=chartHeight-padY-(node.count/maxCount)*innerHeight;node.circle.setAttribute('cx',String(x));node.circle.setAttribute('cy',String(y));node.label.setAttribute('x',String(x));node.label.setAttribute('y',String(chartHeight-9));return {node,x,y};});
        const points=plotted.map(({x,y})=>`${x},${y}`).join(' ');line.setAttribute('points',points);area.setAttribute('points',plotted.length?`${padX},${chartHeight-padY} ${points} ${plotted.at(-1)!.x},${chartHeight-padY}`:'');
        const pixelsPerYear=innerWidth/yearSpan;const labelStep=niceStep(54/Math.max(.001,pixelsPerYear));
        plotted.forEach(({node})=>{const endpoint=node.year===minYear||node.year===maxYear;node.label.toggleAttribute('hidden',!endpoint&&(node.year-minYear)%labelStep!==0);});
        zoomLabel.value=`${Math.round(zoom*100)}%`;
      };
      const setZoom=(next:number,clientX=yearsTimeline.getBoundingClientRect().left+yearsTimeline.clientWidth/2)=>{
        const rect=yearsTimeline.getBoundingClientRect();const anchor=clamp(clientX-rect.left,0,rect.width);const ratio=(yearsTimeline.scrollLeft+anchor)/Math.max(1,yearsTimeline.scrollWidth);
        zoom=clamp(next,1,8);renderTimeline();yearsTimeline.scrollLeft=ratio*yearsTimeline.scrollWidth-anchor;
      };
      panel.querySelector('[data-years-zoom-out]')?.addEventListener('click',()=>setZoom(zoom/1.25));
      panel.querySelector('[data-years-zoom-in]')?.addEventListener('click',()=>setZoom(zoom*1.25));
      panel.querySelector('[data-years-zoom-reset]')?.addEventListener('click',()=>{zoom=1;yearsTimeline.scrollLeft=0;renderTimeline();});
      expandButton.addEventListener('click',()=>{expanded=!expanded;panel.classList.toggle('is-expanded',expanded);document.body.classList.toggle('years-timeline-expanded',expanded);expandButton.setAttribute('aria-pressed',String(expanded));expandButton.setAttribute('aria-label',expanded?'Collapse timeline':'Expand timeline');window.requestAnimationFrame(renderTimeline);});
      yearsTimeline.addEventListener('wheel',(event)=>{if(!event.ctrlKey&&!event.metaKey)return;event.preventDefault();setZoom(zoom*Math.exp(-event.deltaY*.008),event.clientX);},{passive:false});
      let pinchDistance=0;let pinchZoom=1;
      const touchDistance=(touches:TouchList)=>Math.hypot(touches[0].clientX-touches[1].clientX,touches[0].clientY-touches[1].clientY);
      yearsTimeline.addEventListener('touchstart',(event)=>{if(event.touches.length!==2)return;pinchDistance=touchDistance(event.touches);pinchZoom=zoom;},{passive:true});
      yearsTimeline.addEventListener('touchmove',(event)=>{if(event.touches.length!==2||!pinchDistance)return;event.preventDefault();const center=(event.touches[0].clientX+event.touches[1].clientX)/2;setZoom(pinchZoom*(touchDistance(event.touches)/pinchDistance),center);},{passive:false});
      yearsTimeline.addEventListener('touchend',(event)=>{if(event.touches.length<2)pinchDistance=0;},{passive:true});
      new ResizeObserver(()=>renderTimeline()).observe(yearsTimeline);
      document.addEventListener('keydown',(event)=>{if(event.key==='Escape'&&expanded)expandButton.click();});
      renderTimeline();
    }

    const voiceSettingsRoot = document.querySelector<HTMLElement>('[data-voice-settings]');
    if (voiceSettingsRoot && 'speechSynthesis' in window) {
      const key = 'seshat.read-aloud.v1';
      const readSettings = () => { try { return { engine:'native', voice:'', rate:1, nativeVoices:[], ...JSON.parse(localStorage.getItem(key) || '{}') }; } catch { return { engine:'native', voice:'', rate:1, nativeVoices:[] }; } };
      const list = voiceSettingsRoot.querySelector<HTMLElement>('[data-voice-list]')!;
      const search = voiceSettingsRoot.querySelector<HTMLInputElement>('[data-voice-search]')!;
      const summary = voiceSettingsRoot.querySelector<HTMLElement>('[data-voice-summary]')!;
      let voices: SpeechSynthesisVoice[] = [];
      const save = (selected: string[]) => { const settings = readSettings(); localStorage.setItem(key, JSON.stringify({ ...settings, nativeVoices:selected })); };
      const render = () => {
        voices = speechSynthesis.getVoices().sort((a,b) => a.lang.localeCompare(b.lang) || a.name.localeCompare(b.name));
        const settings = readSettings(); const selected = new Set<string>(settings.nativeVoices || []); const query = search.value.trim().toLowerCase();
        list.replaceChildren();
        voices.filter((voice) => !query || `${voice.name} ${voice.lang}`.toLowerCase().includes(query)).forEach((voice) => {
          const label=document.createElement('label'); const checkbox=document.createElement('input'); checkbox.type='checkbox'; checkbox.checked=selected.has(voice.name);
          const text=document.createElement('span'); text.textContent=voice.name; const language=document.createElement('small'); language.textContent=`${voice.lang}${voice.localService?' · local':''}`;
          checkbox.onchange=()=>{checkbox.checked?selected.add(voice.name):selected.delete(voice.name);save([...selected]);summary.textContent=selected.size?`${selected.size} of ${voices.length} shown`:`all ${voices.length} shown`;};
          label.append(checkbox,text,language);list.appendChild(label);
        });
        summary.textContent=selected.size?`${selected.size} of ${voices.length} shown`:`all ${voices.length} shown`;
      };
      search.addEventListener('input',render);
      voiceSettingsRoot.querySelector('[data-microsoft-only]')?.addEventListener('click',()=>{save(voices.filter((voice)=>/Microsoft/i.test(voice.name)).map((voice)=>voice.name));render();});
      voiceSettingsRoot.querySelector('[data-show-all]')?.addEventListener('click',()=>{save([]);render();});
      speechSynthesis.addEventListener('voiceschanged',render); render();
    }
    const chirpVoice = document.querySelector<HTMLSelectElement>('[data-chirp-voice]');
    if (chirpVoice) {
      const key='seshat.read-aloud.v1'; let settings:any={};try{settings=JSON.parse(localStorage.getItem(key)||'{}');}catch{}
      if ([...chirpVoice.options].some((option)=>option.value===settings.voice)) chirpVoice.value=settings.voice;
      chirpVoice.addEventListener('change',()=>{let next:any={};try{next=JSON.parse(localStorage.getItem(key)||'{}');}catch{}localStorage.setItem(key,JSON.stringify({...next,voice:chirpVoice.value}));});
    }

    const zoteroRoot = document.querySelector<HTMLElement>('[data-zotero-settings]');
    if (zoteroRoot) {
      const form=zoteroRoot.querySelector<HTMLFormElement>('[data-zotero-form]')!;
      const output=zoteroRoot.querySelector<HTMLOutputElement>('[data-zotero-output]')!;
      const state=zoteroRoot.querySelector<HTMLElement>('[data-zotero-state]')!;
      const previewButton=zoteroRoot.querySelector<HTMLButtonElement>('[data-zotero-preview]')!;
      const syncButton=zoteroRoot.querySelector<HTMLButtonElement>('[data-zotero-sync]')!;
      const disconnectButton=zoteroRoot.querySelector<HTMLButtonElement>('[data-zotero-disconnect]')!;
      const credentialState=zoteroRoot.querySelector<HTMLElement>('[data-zotero-credential]')!;
      const previewResult=zoteroRoot.querySelector<HTMLElement>('[data-zotero-preview-result]')!;
      let previewVersion=0;
      const busy=(value:boolean)=>{[...form.querySelectorAll<HTMLButtonElement>('button')].forEach((button)=>button.disabled=value);if(!value){previewButton.disabled=zoteroRoot.dataset.connected!=='true';syncButton.disabled=!previewVersion;}};
      form.addEventListener('submit',async(event)=>{
        event.preventDefault();busy(true);output.value='Verifying Zotero permissions…';
        const data=new FormData(form);const body={apiKey:String(data.get('apiKey')||''),syncMode:String(data.get('syncMode')||'bidirectional'),analyzeAutomatically:data.get('analyzeAutomatically')==='on',continuousSync:data.get('continuousSync')==='on',syncIntervalMinutes:Number(data.get('syncIntervalMinutes')||15)};
        const response=await fetch('/api/zotero/connection',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(body)});const result=await response.json().catch(()=>({}));
        if(response.ok){zoteroRoot.dataset.connected='true';state.textContent=`${result.username} · ${result.continuousSync?'continuous sync':'connected'}`;previewButton.disabled=false;disconnectButton.hidden=false;form.querySelector<HTMLInputElement>('[name=apiKey]')!.value='';credentialState.textContent='● key stored encrypted on the server';credentialState.dataset.stored='true';output.value=result.continuousSync?'Connection saved. Continuous synchronization is active.':'Connection saved. Run Preview before synchronizing.';}
        else output.value=result.error||'Zotero connection failed.';busy(false);
      });
      previewButton.addEventListener('click',async()=>{
        busy(true);previewVersion=0;syncButton.disabled=true;output.value='Reading Zotero structure and checking duplicates…';
        const response=await fetch('/api/zotero/preview',{cache:'no-store'});const result=await response.json().catch(()=>({}));
        if(!response.ok){output.value=result.error||'Preview failed.';busy(false);return;}
        previewVersion=Number(result.remote.libraryVersion||0);const changes=result.changes||{};
        previewResult.hidden=false;previewResult.innerHTML=`<article><span>Remote</span><strong>${Number(result.remote.items).toLocaleString()}</strong><small>${Number(result.remote.collections).toLocaleString()} collections · version ${previewVersion}</small></article><article><span>Already mapped</span><strong>${Number(result.local.mapped).toLocaleString()}</strong><small>${Number(result.local.items).toLocaleString()} current Seshat items</small></article><article><span>Safe merges</span><strong>${Number(changes.automaticMerges||0).toLocaleString()}</strong><small>unique DOI or ISBN matches</small></article><article><span>Review candidates</span><strong>${Number(changes.possibleDuplicates||0).toLocaleString()}</strong><small>not merged automatically</small></article><article><span>New items</span><strong>${Number(changes.newItems||0).toLocaleString()}</strong><small>will be created below Zotero/</small></article>`;
        output.value=`Preview ready · ${result.plan.mode} · analysis ${result.plan.analyzeAutomatically?'enabled':'deferred'}.`;busy(false);
      });
      syncButton.addEventListener('click',async()=>{
        if(!previewVersion)return;busy(true);output.value='Synchronizing Zotero. Keep this page open…';
        const response=await fetch('/api/zotero/sync',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({confirmLibraryVersion:previewVersion})});const result=await response.json().catch(()=>({}));
        if(response.status===409){previewVersion=0;output.value='Zotero changed after the preview. Run Preview again.';busy(false);return;}
        if(!response.ok){output.value=result.error||'Synchronization failed.';busy(false);return;}
        output.value=`Sync complete · pulled ${result.pulled.items} · merged ${result.pulled.merged} · pushed ${result.pushed.items} · ${result.conflicts.length} conflicts.`;previewVersion=0;syncButton.disabled=true;window.setTimeout(()=>location.reload(),1800);
      });
      disconnectButton.addEventListener('click',async()=>{
        if(!confirm('Disconnect Zotero? Mirrored Seshat items and folders will remain.'))return;busy(true);
        const response=await fetch('/api/zotero/connection',{method:'DELETE'});if(response.ok){zoteroRoot.dataset.connected='false';state.textContent='not connected';credentialState.textContent='No key stored';credentialState.dataset.stored='false';disconnectButton.hidden=true;previewVersion=0;output.value='Zotero disconnected. Mirrored data was preserved.';}else output.value='Could not disconnect Zotero.';busy(false);
      });
    }

    // 1. Recover catalog form
    const recoverForm = document.querySelector<HTMLFormElement>('[data-recover-catalog]');
    recoverForm?.addEventListener('submit', async (event) => {
      event.preventDefault(); const button = recoverForm.querySelector<HTMLButtonElement>('button'); const output = recoverForm.querySelector<HTMLOutputElement>('output');
      const previousEmail = String(new FormData(recoverForm).get('previousEmail') || ''); if (!button || !output) return;
      button.disabled = true; output.value = 'Checking previous catalog…';
      const response = await fetch('/api/account/recover', { method:'POST', headers:{'content-type':'application/json'}, body:JSON.stringify({ previousEmail }) });
      const result = await response.json().catch(() => ({}));
      if (response.ok) { output.value = 'Catalog recovered. Reloading…'; location.reload(); return; }
      const labels: Record<string,string> = { catalog_already_linked:'That catalog already belongs to another identity.', duplicate_items_require_review:'Both catalogs contain the same original file; review is required before merging.', library_names_require_review:'Both catalogs contain a library with the same name; rename one before merging.', previous_catalog_not_found:'No previous catalog was found for that email.', stable_identity_required:'Sign out and back in to refresh the stable Authentik identity.' };
      output.value = labels[result.error] || result.error || 'Recovery failed.'; button.disabled = false;
    });

    // 2. Associate secondary email form
    const associateForm = document.querySelector<HTMLFormElement>('[data-associate-email]');
    associateForm?.addEventListener('submit', async (event) => {
      event.preventDefault(); const button = associateForm.querySelector<HTMLButtonElement>('button'); const output = associateForm.querySelector<HTMLOutputElement>('output');
      const secondaryEmail = String(new FormData(associateForm).get('secondaryEmail') || ''); if (!button || !output) return;
      button.disabled = true; output.value = 'Associating login email…';
      const response = await fetch('/api/account/associate', { method:'POST', headers:{'content-type':'application/json'}, body:JSON.stringify({ secondaryEmail }) });
      const result = await response.json().catch(() => ({}));
      if (response.ok) { output.value = 'Email linked successfully. Reloading…'; location.reload(); return; }
      const labels: Record<string,string> = { catalog_already_linked:'That catalog already belongs to another identity.', duplicate_items_require_review:'Both catalogs contain the same original file; review is required before merging.', library_names_require_review:'Both catalogs contain a library with the same name; rename one before merging.', stable_identity_required:'Sign out and back in to refresh login identity.' };
      output.value = labels[result.error] || result.error || 'Link failed.'; button.disabled = false;
    });
  </script>
</Shell>

