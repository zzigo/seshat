---
import Shell from '../components/Shell.astro';
import { contributorSummary, formatPublicationYear } from '@seshat/core';
import { getCatalog, isSessionAccountAdmin, ownerKeyFor, sessionIdentity } from '../lib/catalog';
import { BOOKMARK_GROUP_COLORS, BOOKMARK_GROUP_ICONS } from '../lib/bookmark-groups';
import { chirpAccessAllowed } from '../lib/chirp-access';
import { chirpMonth, CHIRP_VOICES, DEFAULT_CHIRP_LIMIT, nextChirpRenewal } from '../lib/chirp';
import { detectEmergence } from '../lib/emergence';
import { getZoteroConnectionStatus } from '../lib/zotero-connection';
import { readingProgressPercent } from '../lib/reading-progress';

const session = (Astro.locals as any).session; const identity = sessionIdentity(session);
const ownerKey = ownerKeyFor(identity.email);
const catalog = getCatalog();
await catalog.ensureSchema();
const [stats, recentReadings, completedReadings, bookmarkGroups, emergenceRows, zoteroStatus] = await Promise.all([
  catalog.dashboardStats(ownerKey), catalog.listRecentReadings(ownerKey, 20), catalog.listCompletedReadings(ownerKey, 10), catalog.listBookmarkGroups(ownerKey),
  catalog.pool.query(`SELECT id,title,(issued->>'year')::int AS year FROM catalog_references
    WHERE owner_key=$1 AND (issued->>'year') ~ '^-?[0-9]{1,4}$' ORDER BY updated_at DESC LIMIT 10000`, [ownerKey]),
  getZoteroConnectionStatus(ownerKey),
]);
const emergenceSignals = detectEmergence(emergenceRows.rows.map((row:any) => ({ id: row.id, title: row.title, year: Number(row.year) })));
const emergenceItems = Object.fromEntries(emergenceRows.rows.map((row:any) => [row.id, { id:row.id, title:row.title, year:Number(row.year) }]));
const admin = isSessionAccountAdmin(session);
const linkedEmailsQuery = await catalog.pool.query(
  'SELECT DISTINCT current_email FROM catalog_identities WHERE owner_key = $1 ORDER BY current_email ASC',
  [ownerKeyFor(identity.email)]
);
const linkedEmails = linkedEmailsQuery.rows.map((row: any) => row.current_email).filter((email: string) => email.toLowerCase() !== identity.email.toLowerCase());
const chirpEnabled = chirpAccessAllowed(identity.email); const chirpLimit = Math.max(1,Number(process.env.GOOGLE_TTS_MONTHLY_CHARACTER_LIMIT || DEFAULT_CHIRP_LIMIT));
const chirpUsed = chirpEnabled ? await catalog.getTtsUsage('google-chirp-3-hd',chirpMonth()) : 0;
const years = stats.publicationYears; const width = 760; const height = 250; const padX = 42; const padY = 32;
const minYear = years[0]?.year || new Date().getFullYear(); const maxYear = years.at(-1)?.year || minYear;
const maxCount = Math.max(1, ...years.map((item) => item.count)); const span = Math.max(1, maxYear - minYear);
const point = (item: { year: number; count: number }) => ({
  x: padX + ((item.year - minYear) / span) * (width - padX * 2),
  y: height - padY - (item.count / maxCount) * (height - padY * 2),
});
const points = years.map(point); const line = points.map((item) => `${item.x},${item.y}`).join(' ');
const area = points.length ? `${padX},${height - padY} ${line} ${points.at(-1)!.x},${height - padY}` : '';
const number = (value: number) => new Intl.NumberFormat('en').format(value);
const personLine = (contributors: unknown[]) => contributorSummary(contributors as any) || 'Unknown persons';
const dashboardData = JSON.stringify({
  groups: bookmarkGroups.map((group) => ({ id:group.id,name:group.name,color:group.color,icon:group.icon,itemIds:group.items.map((item)=>item.id) })),
  emergenceSignals, emergenceItems,
}).replace(/</g, '\\u003c');
const themePresets = [
  { id:'papyrus', mode:'light', label:'Papyrus', paper:'#f1efe6', ink:'#17231d', accent:'#244f3a' },
  { id:'alabaster', mode:'light', label:'Alabaster', paper:'#f7f7f3', ink:'#202420', accent:'#315c46' },
  { id:'ivory', mode:'light', label:'Ivory', paper:'#f7f0df', ink:'#302a21', accent:'#53623a' },
  { id:'sage', mode:'light', label:'Sage', paper:'#edf1e7', ink:'#1d2b21', accent:'#365f44' },
  { id:'mist', mode:'light', label:'Mist', paper:'#eef3f4', ink:'#17282d', accent:'#356c78' },
  { id:'sepia', mode:'light', label:'Sepia', paper:'#eee2cc', ink:'#3a2b1f', accent:'#65573b' },
  { id:'porcelain', mode:'light', label:'Porcelain', paper:'#eef2f8', ink:'#1d2938', accent:'#3b5f87' },
  { id:'rose', mode:'light', label:'Rose', paper:'#f5eeee', ink:'#352629', accent:'#78525d' },
  { id:'sand', mode:'light', label:'Sand', paper:'#efe6d4', ink:'#332d23', accent:'#5e6742' },
  { id:'high-light', mode:'light', label:'High contrast', paper:'#ffffff', ink:'#101010', accent:'#005a38' },
  { id:'ink', mode:'dark', label:'Ink', paper:'#171717', ink:'#fafafa', accent:'#69b88e' },
  { id:'charcoal', mode:'dark', label:'Charcoal', paper:'#1c1e1d', ink:'#f0f2f0', accent:'#70b08c' },
  { id:'midnight', mode:'dark', label:'Midnight', paper:'#111827', ink:'#f4f6fb', accent:'#7ca6d9' },
  { id:'forest', mode:'dark', label:'Forest', paper:'#122019', ink:'#eef7f1', accent:'#6eae83' },
  { id:'aubergine', mode:'dark', label:'Aubergine', paper:'#211722', ink:'#f6eef5', accent:'#bb7aa7' },
  { id:'umber', mode:'dark', label:'Umber', paper:'#241b16', ink:'#f6efe8', accent:'#b88c6a' },
  { id:'slate', mode:'dark', label:'Slate', paper:'#1b2228', ink:'#eef2f5', accent:'#78a0b7' },
  { id:'navy', mode:'dark', label:'Navy', paper:'#0f1c2b', ink:'#eff5fb', accent:'#71a5d4' },
  { id:'espresso', mode:'dark', label:'Espresso', paper:'#211915', ink:'#f4eee9', accent:'#a88f6e' },
  { id:'graphite', mode:'dark', label:'Graphite', paper:'#161719', ink:'#f2f2f2', accent:'#93a880' },
  { id:'high-dark', mode:'dark', label:'High contrast', paper:'#050505', ink:'#ffffff', accent:'#62d39a' },
] as const;
---

<Shell title="Dashboard — Seshat">
  <section class="account-dashboard">
    <header class="dashboard-head">
      <div><div class="eyebrow">Personal archive</div><h1>{session.user.name || identity.email}</h1><p>{identity.email}</p></div>
      <a class="button quiet" href="/workspace">Open workspace →</a>
    </header>

    <section class="dashboard-home-grid" aria-label="Reading home">
      <section class="dashboard-panel recent-reading-panel">
        <header><div><span>Return</span><h2>Recent readings</h2></div><small>last 20</small></header>
        <div class="dashboard-item-list">
          {recentReadings.map((item) => <button type="button" class="dashboard-reading-item" data-dashboard-item={item.id} data-item-title={item.title}>
            <span><strong>{item.title}</strong><small>{personLine(item.contributors)} · {item.issued?.year ? formatPublicationYear(Number(item.issued.year)) : item.type}</small></span>
            <progress class="reading-progress-meter" max="100" value={readingProgressPercent(item.location)} aria-label={`${readingProgressPercent(item.location)}% read`}></progress>
            <time datetime={item.readAt}>{new Date(item.readAt).toLocaleDateString(undefined,{month:'short',day:'numeric'})}</time>
          </button>)}
          {!recentReadings.length && <div class="dashboard-empty">Documents appear here as soon as you read or annotate them.</div>}
        </div>
      </section>

      <section class="dashboard-panel bookmark-home-panel">
        <header>
          <div><span>Working sets</span><h2>Bookmark groups</h2></div>
          <button type="button" class="bookmark-new-button" data-new-bookmark-group>＋ New group</button>
        </header>
        <div class="bookmark-groups">
          {bookmarkGroups.map((group) => <article class="bookmark-group" data-bookmark-color={group.color} data-bookmark-group={group.id}>
            <header>
              <span class="bookmark-group-icon" data-bookmark-icon={group.icon} aria-hidden="true"></span>
              <div><strong>{group.name}</strong><small>{group.items.length} {group.items.length === 1 ? 'item' : 'items'}</small></div>
              <button type="button" data-edit-bookmark-group={group.id} aria-label={`Edit ${group.name}`}>•••</button>
            </header>
            <div class="bookmark-group-items">
              {group.items.slice(0,8).map((item) => <button type="button" class="dashboard-reading-item" data-dashboard-item={item.id} data-item-title={item.title}>
                <span><strong>{item.title}</strong><small>{personLine(item.contributors)}{item.issued?.year ? ` · ${formatPublicationYear(Number(item.issued.year))}` : ''}</small></span>
              </button>)}
              {!group.items.length && <p>Right-click a recent item to add it here.</p>}
              {group.items.length > 8 && <small class="bookmark-more">+ {group.items.length-8} more</small>}
            </div>
          </article>)}
          {!bookmarkGroups.length && <button type="button" class="bookmark-empty" data-new-bookmark-group><span>Create a focused working set</span><small>Groups are for active themes, questions or projects — not another folder tree.</small></button>}
        </div>
      </section>
    </section>

    {completedReadings.length > 0 && <section class="dashboard-panel completed-reading-panel" aria-label="Read items">
      <header><div><span>Completed</span><h2>Read items</h2></div><small>last {completedReadings.length}</small></header>
      <div class="completed-reading-list">
        {completedReadings.map((item) => <button type="button" class="dashboard-reading-item completed-reading-item" data-dashboard-item={item.id} data-item-title={item.title}>
          <span><strong>{item.title}</strong><small>{personLine(item.contributors)}{item.issued?.year ? ` · ${formatPublicationYear(Number(item.issued.year))}` : ''}</small></span>
          <time datetime={item.completedAt || item.readAt}>{new Date(item.completedAt || item.readAt).toLocaleDateString(undefined,{year:'numeric',month:'short',day:'numeric'})}</time>
        </button>)}
      </div>
    </section>}

    <section class="dashboard-panel emergence-panel" data-emergence-panel>
      <header><div><span>Corpus signal</span><h2>Emerging language</h2></div><small>rising title phrases</small></header>
      {emergenceSignals.length ? <div class="emergence-layout">
        <div class="emergence-signals">
          {emergenceSignals.map((signal,index) => <button type="button" data-emergence-signal={index} aria-pressed={index===0?'true':'false'}>
            <span>{signal.phrase}</span><i style={`--signal:${Math.min(100,30+signal.strength*10)}%`}></i><small>{signal.count} items · rises {formatPublicationYear(signal.peakYear)}</small>
          </button>)}
        </div>
        <div class="emergence-result" data-emergence-result aria-live="polite"></div>
      </div> : <div class="dashboard-empty">More repeated title language is needed before a signal can emerge.</div>}
    </section>

    <div class="dashboard-totals">
      <article><span>Items</span><strong>{number(stats.totals.items)}</strong></article>
      <article><span>Words extracted</span><strong>{number(stats.totals.words)}</strong></article>
      <article><span>Annotations</span><strong>{number(stats.totals.annotations)}</strong></article>
      <article><span>Libraries</span><strong>{number(stats.totals.libraries)}</strong></article>
      <article><span>OpenAlex concepts</span><strong>{number(stats.totals.concepts)}</strong></article>
    </div>

    <section class="dashboard-panel years-panel">
      <header>
        <div><span>Publication history</span><h2>Items by year</h2></div>
        <div class="years-head-tools">
          <small>{minYear === maxYear ? formatPublicationYear(minYear) : `${formatPublicationYear(minYear)}—${formatPublicationYear(maxYear)}`}</small>
          {years.length > 0 && <div class="years-controls" aria-label="Timeline controls">
            <button type="button" data-years-zoom-out aria-label="Zoom timeline out" title="Zoom out">
              <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10" /></svg>
            </button>
            <output data-years-zoom-label>100%</output>
            <button type="button" data-years-zoom-in aria-label="Zoom timeline in" title="Zoom in">
              <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M3 8h10M8 3v10" /></svg>
            </button>
            <button type="button" data-years-zoom-reset aria-label="Return timeline to the present at 1000%" title="Present · 1000%">
              <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M2.5 5V2.5H5M11 2.5h2.5V5M13.5 11v2.5H11M5 13.5H2.5V11" /></svg>
            </button>
            <button type="button" data-years-expand aria-label="Expand timeline" aria-pressed="false" title="Expand timeline">
              <svg viewBox="0 0 16 16" aria-hidden="true"><path d="M2.5 6V2.5H6M10 2.5h3.5V6M13.5 10v3.5H10M6 13.5H2.5V10" /></svg>
            </button>
          </div>}
        </div>
      </header>
      {years.length ? (
        <div class="years-viewport" data-years-timeline>
          <svg data-years-svg viewBox={`0 0 ${width} ${height}`} role="img" aria-label="Publication items by year">
            {[0,.25,.5,.75,1].map((ratio) => <line data-grid-ratio={ratio} x1={padX} x2={width-padX} y1={padY + ratio*(height-padY*2)} y2={padY + ratio*(height-padY*2)} />)}
            <polygon data-years-area points={area} class="year-area" />
            <polyline data-years-line points={line} class="year-line" />
            {years.map((item) => { const p = point(item); return <g data-year-point data-year={item.year} data-count={item.count}><circle cx={p.x} cy={p.y} r="4"><title>{formatPublicationYear(item.year)}: {item.count}</title></circle><text x={p.x} y={height-8}>{formatPublicationYear(item.year)}</text></g>; })}
          </svg>
        </div>
      ) : <div class="dashboard-empty">No publication years yet.</div>}
    </section>

    <div class="dashboard-columns">
      <section class="dashboard-panel ranking-panel">
        <header><div><span>Corpus</span><h2>Top authors</h2></div><small>items</small></header>
        <ol>{stats.topAuthors.map((author) => <li><span>{author.name}</span><b>{author.count}</b></li>)}</ol>
        {!stats.topAuthors.length && <div class="dashboard-empty">No structured authors yet.</div>}
      </section>
      <section class="dashboard-panel ranking-panel tags-panel">
        <header><div><span>Vocabulary</span><h2>Top tags</h2></div><small>items</small></header>
        <div class="tag-cloud">{stats.topTags.map((tag) => <span style={`--weight:${Math.max(.72,Math.min(1.45,.72+tag.count*.1))}`}>{tag.name}<b>{tag.count}</b></span>)}</div>
        {!stats.topTags.length && <div class="dashboard-empty">No tags yet.</div>}
      </section>
    </div>

    <section class="dashboard-panel concepts-panel">
      <header><div><span>Knowledge graph</span><h2>Concept network</h2></div><small>connected items</small></header>
      <div class="concept-list">{stats.topConcepts.map((concept) => <span><i></i><em>{concept.name}</em><b>{concept.count}</b></span>)}</div>
      {!stats.topConcepts.length && <div class="dashboard-empty">Resolve papers with OpenAlex to discover concepts.</div>}
    </section>

    <section class="dashboard-panel theme-panel dashboard-setup-panel" data-theme-settings data-dashboard-setup data-setup-id="appearance">
      <header><div><span>Interface</span><h2>Appearance</h2></div><div class="setup-panel-actions"><small data-theme-current>current theme</small><button type="button" data-setup-toggle aria-label="Expand Appearance" aria-expanded="false"><svg viewBox="0 0 16 16" aria-hidden="true"><path d="m4 6 4 4 4-4"/></svg></button></div></header>
      <div class="theme-groups">
        {(['light','dark'] as const).map((mode) => <section>
          <h3>{mode} themes</h3>
          <div class="theme-list">
            {themePresets.filter((theme) => theme.mode === mode).map((theme) =>
              <button type="button" data-theme-choice data-theme-mode={theme.mode} data-theme-preset={theme.id} aria-pressed="false" style={`--theme-paper:${theme.paper};--theme-ink:${theme.ink};--theme-accent:${theme.accent}`}>
                <i aria-hidden="true"><b></b></i><span>{theme.label}</span>
              </button>
            )}
          </div>
        </section>)}
      </div>
    </section>

    <section class="dashboard-panel zotero-panel dashboard-setup-panel" data-zotero-settings data-connected={String(zoteroStatus.connected)} data-dashboard-setup data-setup-id="zotero">
      <header>
        <div><span>Bibliography bridge</span><h2>Zotero synchronization</h2></div>
        <div class="setup-panel-actions"><small data-zotero-state>{zoteroStatus.connected ? `${zoteroStatus.username} · ${zoteroStatus.continuousSync === false ? 'connected' : 'continuous sync'}` : 'not connected'}</small><button type="button" data-setup-toggle aria-label="Expand Zotero synchronization" aria-expanded="false"><svg viewBox="0 0 16 16" aria-hidden="true"><path d="m4 6 4 4 4-4"/></svg></button></div>
      </header>
      <form data-zotero-form>
        <label class="zotero-key-field"><span>Zotero API key</span><input type="password" name="apiKey" autocomplete="off" placeholder={zoteroStatus.connected ? 'Leave blank to keep the stored key' : 'Paste a library API key'} /><small class="zotero-credential-state" data-zotero-credential data-stored={String(zoteroStatus.apiKeyStored)}>{zoteroStatus.apiKeyStored ? '● key stored encrypted on the server' : 'No key stored'}</small></label>
        <label><span>Direction</span><select name="syncMode">
          <option value="bidirectional" selected={zoteroStatus.syncMode === 'bidirectional' || !zoteroStatus.syncMode}>Bidirectional · read + write</option>
          <option value="pull" selected={zoteroStatus.syncMode === 'pull'}>Pull from Zotero</option>
          <option value="push" selected={zoteroStatus.syncMode === 'push'}>Push to Zotero</option>
        </select></label>
        <label class="zotero-analysis-check"><input type="checkbox" name="analyzeAutomatically" checked={zoteroStatus.analyzeAutomatically !== false} /><span><b>Analyze linked files automatically</b><small>Turn off before a massive first synchronization.</small></span></label>
        <div class="zotero-sync-schedule">
          <label class="zotero-continuous-check"><input type="checkbox" name="continuousSync" checked={zoteroStatus.continuousSync !== false} /><span><b>Continuous synchronization</b><small>The key remains encrypted on the server; this page does not need to stay open.</small></span></label>
          <label><span>Check Zotero every</span><select name="syncIntervalMinutes">
            {[5, 15, 30, 60].map((minutes) => <option value={minutes} selected={(zoteroStatus.syncIntervalMinutes || 15) === minutes}>{minutes} minutes</option>)}
          </select></label>
        </div>
        <div class="zotero-actions">
          <button class="button primary" type="submit">Test & save</button>
          <button class="button quiet" type="button" data-zotero-preview disabled={!zoteroStatus.connected}>Preview sync</button>
          <button class="button quiet" type="button" data-zotero-sync disabled>Sync now</button>
          <button class="button quiet" type="button" data-zotero-disconnect hidden={!zoteroStatus.connected}>Disconnect</button>
        </div>
        <output data-zotero-output aria-live="polite"></output>
      </form>
      <div class="zotero-contract">
        <div><span>Local scope</span><strong>Zotero/</strong><small>Only this metafolder participates in remote writes.</small></div>
        <div><span>Binary originals</span><strong>Wasabi</strong><small>Zotero sync changes metadata, collections and membership.</small></div>
        <div><span>Deletion policy</span><strong>Non-destructive</strong><small>No automatic remote or local deletions.</small></div>
        <div><span>Last synchronization</span><strong>{zoteroStatus.lastSyncedAt ? new Date(zoteroStatus.lastSyncedAt).toLocaleString() : 'Never'}</strong><small>{zoteroStatus.libraryVersion ? `library version ${zoteroStatus.libraryVersion}${zoteroStatus.lastCheckedAt ? ` · checked ${new Date(zoteroStatus.lastCheckedAt).toLocaleString()}` : ''}` : 'Preview required before first sync'}</small></div>
      </div>
      <div class="zotero-preview" data-zotero-preview-result hidden></div>
    </section>

    <section class="dashboard-panel voice-panel dashboard-setup-panel" data-voice-settings data-dashboard-setup data-setup-id="voice">
      <header><div><span>Reader</span><h2>Voice settings</h2></div><div class="setup-panel-actions"><small data-voice-summary>loading installed voices…</small><button type="button" data-setup-toggle aria-label="Expand Voice settings" aria-expanded="false"><svg viewBox="0 0 16 16" aria-hidden="true"><path d="m4 6 4 4 4-4"/></svg></button></div></header>
      <div class="voice-settings-body">
        <p>Select the browser and Microsoft voices shown in the Reader menu. With no selection, every installed voice remains visible.</p>
        <div class="voice-settings-tools">
          <label><span>Find installed voice</span><input type="search" data-voice-search placeholder="Name or language…" /></label>
          <button class="button quiet" type="button" data-microsoft-only>Microsoft only</button>
          <button class="button quiet" type="button" data-show-all>Show all</button>
        </div>
        <div class="voice-checklist" data-voice-list aria-live="polite"></div>
        {chirpEnabled && <div class="chirp-dashboard-settings">
          <div><span>Private cloud provider</span><strong>Google Chirp 3 HD</strong><small>{process.env.GOOGLE_CLOUD_PROJECT || 'not configured'}</small></div>
          <div><span>Monthly balance</span><strong>{number(Math.max(0,chirpLimit-chirpUsed))} / {number(chirpLimit)}</strong><small>renews {new Date(nextChirpRenewal()).toLocaleDateString()}</small></div>
          <label><span>Preferred Chirp voice</span><select data-chirp-voice><option value="">Automatic by item language</option>{CHIRP_VOICES.map((voice)=><option value={voice.id}>{voice.label}</option>)}</select></label>
        </div>}
      </div>
    </section>

    <section class="dashboard-panel account-panel dashboard-setup-panel" data-dashboard-setup data-setup-id="account">
      <header><div><span>Identity</span><h2>Logto account</h2></div><div class="setup-panel-actions"><small>associated logins</small><button type="button" data-setup-toggle aria-label="Expand Logto account" aria-expanded="false"><svg viewBox="0 0 16 16" aria-hidden="true"><path d="m4 6 4 4 4-4"/></svg></button></div></header>
      <dl>
        <div><dt>Primary email</dt><dd>{identity.email}</dd></div>
        <div><dt>Linked emails</dt><dd>{linkedEmails.length ? linkedEmails.join(', ') : 'None linked'}</dd></div>
        <div><dt>Subject</dt><dd>{identity.subject ? `${identity.subject.slice(0,8)}…` : 'refresh login required'}</dd></div>
      </dl>

      <form data-associate-email>
        <label><span>Link secondary login email</span><input type="email" name="secondaryEmail" required placeholder="secondary@email.example" /></label>
        <button class="button primary" type="submit">Link login email</button>
        <output aria-live="polite"></output>
        <p>This allows you to log in with a second email/identity and access the same catalog workspace. Catalogs will merge if the email already has catalog items.</p>
      </form>

      {admin && (
        <form data-recover-catalog style="border-top:1px dashed var(--line); margin-top:16px; padding-top:16px;">
          <label><span>[Admin] Previous login email</span><input type="email" name="previousEmail" required placeholder="previous@email.example" /></label>
          <button class="button secondary" type="submit">Recover previous catalog</button>
          <output aria-live="polite"></output>
          <p>Administrative tool: links the stable identity to an unclaimed catalog and merges current items when no conflicts exist.</p>
        </form>
      )}
    </section>
    <script is:inline type="application/json" id="dashboard-reading-data" set:html={dashboardData}></script>
    <dialog class="bookmark-group-dialog" data-bookmark-dialog>
      <form method="dialog" data-bookmark-form>
        <header><div><small>BOOKMARK GROUP</small><strong data-bookmark-dialog-title>New working set</strong></div><button type="button" data-bookmark-dialog-close aria-label="Close">×</button></header>
        <label><span>Name</span><input name="name" maxlength="80" required placeholder="e.g. Sonic epistemologies" /></label>
        <fieldset><legend>Color</legend><div class="bookmark-choice-row">{BOOKMARK_GROUP_COLORS.map((color,index)=><label data-bookmark-color={color}><input type="radio" name="color" value={color} checked={index===0}/><i></i><span>{color}</span></label>)}</div></fieldset>
        <fieldset><legend>Icon</legend><div class="bookmark-choice-row icon-choices">{BOOKMARK_GROUP_ICONS.map((icon,index)=><label><input type="radio" name="icon" value={icon} checked={index===0}/><i class="bookmark-group-icon" data-bookmark-icon={icon}></i><span>{icon}</span></label>)}</div></fieldset>
        <output data-bookmark-dialog-output></output>
        <footer><button type="button" class="danger" data-delete-bookmark-group hidden>Delete group</button><span></span><button type="button" data-bookmark-dialog-cancel>Cancel</button><button type="submit" class="primary">Save group</button></footer>
      </form>
    </dialog>
    <dialog class="dashboard-reader-modal" data-reader-modal>
      <header class="reader-modal-toolbar">
        <div class="reader-modal-scroll">
          <strong data-reader-modal-title title="Reader">Reader</strong>
          <button type="button" class="reader-epub-only reader-modal-initial" data-reader-command="toggle-toc" title="Table of contents" aria-label="Table of contents">C</button>
          <output class="reader-epub-only reader-modal-chapter" data-reader-modal-chapter title="Current chapter">cap</output>
          <div class="reader-epub-only reader-modal-font" aria-label="Text size">
            <button type="button" data-reader-command="font-smaller" aria-label="Smaller text">A−</button>
            <button type="button" data-reader-command="font-reset" data-reader-modal-font-scale>100%</button>
            <button type="button" data-reader-command="font-larger" aria-label="Larger text">A+</button>
          </div>
          <button type="button" class="reader-modal-initial" data-reader-modal-theme title="Theme" aria-label="Toggle reader and interface theme">T</button>
          <button type="button" class="reader-modal-read reader-modal-initial" data-reader-command="read" data-reader-modal-read title="Read" aria-label="Read">R</button>
          <span class="reader-modal-tail" aria-hidden="true"></span>
          <button type="button" class="reader-epub-only reader-secondary reader-modal-initial" data-reader-command="toggle-flow" data-reader-modal-flow title="Pages">P</button>
          <button type="button" class="reader-page-control reader-secondary" data-reader-command="previous-page" aria-label="Previous page">‹</button>
          <output class="reader-secondary reader-modal-page" data-reader-modal-page>1 / —</output>
          <button type="button" class="reader-page-control reader-secondary" data-reader-command="next-page" aria-label="Next page">›</button>
          <button type="button" class="reader-pdf-only reader-secondary reader-modal-initial" data-reader-command="zoom-reset" title="Fit current page or spread" aria-label="Fit current page or spread">1</button>
          <button type="button" class="reader-pdf-only reader-secondary reader-modal-initial" data-reader-command="toggle-book" title="Book view" aria-label="Book view">B</button>
          <button type="button" class="reader-pdf-only reader-secondary reader-modal-initial" data-reader-command="toggle-grid" title="Grid view" aria-label="Grid view">G</button>
          <button type="button" class="reader-secondary reader-modal-initial" data-reader-command="play-rendered" data-reader-modal-rendered title="Rendered audio" aria-label="Play rendered audio" hidden>A</button>
          <a class="reader-secondary reader-modal-initial" data-reader-modal-original title="Original file" aria-label="Open original file" target="_blank" rel="noreferrer">O</a>
          <button type="button" class="reader-secondary reader-modal-initial" data-reader-modal-fullscreen title="Fullscreen" aria-label="Open reader fullscreen">F</button>
        </div>
        <button type="button" class="reader-modal-close" data-reader-modal-close aria-label="Close reader">×</button>
      </header>
      <iframe data-reader-frame title="Seshat document reader"></iframe>
    </dialog>
  </section>

  <script>
    import type { ReaderCommandName, ReaderControlsState } from '../lib/reader-controls';
    import { READER_COMMAND_MESSAGE, READER_STATE_MESSAGE } from '../lib/reader-controls';
    type DashboardGroup={id:string;name:string;color:string;icon:string;itemIds:string[]};
    type EmergenceSignal={phrase:string;firstYear:number;peakYear:number;count:number;itemIds:string[]};
    const readingData=JSON.parse(document.getElementById('dashboard-reading-data')?.textContent||'{"groups":[],"emergenceSignals":[],"emergenceItems":{}}') as {groups:DashboardGroup[];emergenceSignals:EmergenceSignal[];emergenceItems:Record<string,{id:string;title:string;year:number}>};
    const readerModal=document.querySelector<HTMLDialogElement>('[data-reader-modal]');
    const readerFrame=readerModal?.querySelector<HTMLIFrameElement>('[data-reader-frame]');
    const readerTitle=readerModal?.querySelector<HTMLElement>('[data-reader-modal-title]');
    const readerThemeButton=readerModal?.querySelector<HTMLButtonElement>('[data-reader-modal-theme]');
    const readerFullscreenButton=readerModal?.querySelector<HTMLButtonElement>('[data-reader-modal-fullscreen]');
    const readerChapter=readerModal?.querySelector<HTMLOutputElement>('[data-reader-modal-chapter]');
    const readerScale=readerModal?.querySelector<HTMLButtonElement>('[data-reader-modal-font-scale]');
    const readerPage=readerModal?.querySelector<HTMLOutputElement>('[data-reader-modal-page]');
    const readerFlow=readerModal?.querySelector<HTMLButtonElement>('[data-reader-modal-flow]');
    const readerRead=readerModal?.querySelector<HTMLButtonElement>('[data-reader-modal-read]');
    const readerRendered=readerModal?.querySelector<HTMLButtonElement>('[data-reader-modal-rendered]');
    const readerOriginal=readerModal?.querySelector<HTMLAnchorElement>('[data-reader-modal-original]');
    let activeReaderId='';
    const applyUnifiedReaderTheme=(mode:string)=>{const preset=localStorage.getItem(`seshat-theme-${mode}-preset`)||(mode==='dark'?'ink':'papyrus');document.documentElement.setAttribute('data-theme',mode);document.documentElement.setAttribute('data-theme-preset',preset);document.documentElement.classList.toggle('dark-theme',mode==='dark');localStorage.setItem('seshat-theme',mode);localStorage.setItem('seshat-theme-preset',preset);readerFrame?.contentWindow?.postMessage({type:'seshat:reader-theme',mode,preset},window.location.origin);window.dispatchEvent(new CustomEvent('seshat:theme-changed',{detail:{theme:mode,preset}}));};
    const closeReader=()=>{if(document.fullscreenElement===readerModal)void document.exitFullscreen();readerModal?.close();document.documentElement.classList.remove('dashboard-reader-open');if(readerFrame)readerFrame.src='about:blank';activeReaderId='';};
    const resetReaderControls=()=>{if(readerChapter)readerChapter.value='cap';if(readerScale)readerScale.textContent='100%';if(readerPage)readerPage.value='1 / —';if(readerFlow){readerFlow.textContent='P';readerFlow.title='Pages';}if(readerRead){readerRead.textContent='R';readerRead.title='Read';readerRead.setAttribute('aria-label','Read');delete readerRead.dataset.readerState;}if(readerRendered)readerRendered.hidden=true;readerModal?.removeAttribute('data-reader-format');};
    const openReader=(id:string,title:string)=>{if(!readerModal||!readerFrame)return;activeReaderId=id;resetReaderControls();if(readerTitle){readerTitle.textContent=title;readerTitle.title=title;}if(readerOriginal)readerOriginal.href=`/api/library/${encodeURIComponent(id)}/original`;readerFrame.src=`/dashboard-reader/${encodeURIComponent(id)}`;document.documentElement.classList.add('dashboard-reader-open');readerModal.showModal();};
    const sendReaderCommand=(command:ReaderCommandName)=>readerFrame?.contentWindow?.postMessage({type:READER_COMMAND_MESSAGE,command},window.location.origin);
    readerModal?.querySelectorAll<HTMLElement>('[data-reader-command]').forEach((control)=>control.addEventListener('click',()=>sendReaderCommand(control.dataset.readerCommand as ReaderCommandName)));
    readerModal?.querySelector('[data-reader-modal-close]')?.addEventListener('click',closeReader);
    readerThemeButton?.addEventListener('click',()=>applyUnifiedReaderTheme((document.documentElement.getAttribute('data-theme')||'light')==='dark'?'light':'dark'));
    readerFrame?.addEventListener('load',()=>{const mode=document.documentElement.getAttribute('data-theme')||'light';const preset=document.documentElement.getAttribute('data-theme-preset')||(mode==='dark'?'ink':'papyrus');readerFrame.contentWindow?.postMessage({type:'seshat:reader-theme',mode,preset},window.location.origin);});
    window.addEventListener('message',(event)=>{if(event.origin!==window.location.origin||event.source!==readerFrame?.contentWindow||event.data?.type!==READER_STATE_MESSAGE)return;const state=(event.data.state||{}) as ReaderControlsState;if(state.format)readerModal?.setAttribute('data-reader-format',state.format);if(readerChapter&&state.chapter){readerChapter.value=state.chapter;readerChapter.title=state.chapter;}if(readerScale&&Number.isFinite(state.fontScale))readerScale.textContent=`${Math.round(Number(state.fontScale)*100)}%`;if(readerPage&&state.pageLabel){readerPage.value=state.pageLabel;readerPage.title=state.pageLabel;}if(readerFlow&&state.flow){const scrolled=state.flow==='scrolled';readerFlow.textContent=scrolled?'S':'P';readerFlow.title=scrolled?'Scroll':'Pages';}if(readerRead&&state.readLabel){const readState=state.readState||'idle';const label=readState==='reading'?'Pause':readState==='paused'?'Resume':String(state.readLabel);readerRead.textContent=readState==='reading'?'P':/load|prepar/i.test(label)?'…':'R';readerRead.title=label;readerRead.setAttribute('aria-label',label);readerRead.dataset.readerState=readState;}if(readerRendered)readerRendered.hidden=!state.hasRendered;if(activeReaderId&&Number.isFinite(state.progress)){const percent=Math.round(Math.max(0,Math.min(1,Number(state.progress)))*100);document.querySelectorAll<HTMLProgressElement>(`[data-dashboard-item="${CSS.escape(activeReaderId)}"] .reading-progress-meter`).forEach((meter)=>{meter.value=percent;meter.setAttribute('aria-label',`${percent}% read`);});}});
    readerFullscreenButton?.addEventListener('click',()=>{if(!readerModal)return;if(document.fullscreenElement===readerModal)void document.exitFullscreen();else void readerModal.requestFullscreen();});
    document.addEventListener('fullscreenchange',()=>{const active=document.fullscreenElement===readerModal;if(readerFullscreenButton){readerFullscreenButton.classList.toggle('active',active);readerFullscreenButton.title=active?'Exit fullscreen':'Fullscreen';readerFullscreenButton.setAttribute('aria-label',active?'Exit reader fullscreen':'Open reader fullscreen');}});
    readerModal?.addEventListener('click',(event)=>{if(event.target===readerModal)closeReader();});
    readerModal?.addEventListener('cancel',(event)=>{event.preventDefault();closeReader();});

    const setupStateKey='seshat.dashboard.setup-folds.v1';
    let setupState:Record<string,boolean>={};try{setupState=JSON.parse(localStorage.getItem(setupStateKey)||'{}');}catch{}
    document.querySelectorAll<HTMLElement>('[data-dashboard-setup]').forEach((panel)=>{const id=panel.dataset.setupId||'';const button=panel.querySelector<HTMLButtonElement>('[data-setup-toggle]');const setCollapsed=(collapsed:boolean)=>{panel.classList.toggle('is-collapsed',collapsed);button?.setAttribute('aria-expanded',String(!collapsed));if(button){button.setAttribute('aria-label',`${collapsed?'Expand':'Collapse'} ${panel.querySelector('h2')?.textContent||'settings'}`);}};setCollapsed(setupState[id]??true);button?.addEventListener('click',()=>{const collapsed=!panel.classList.contains('is-collapsed');setCollapsed(collapsed);setupState[id]=collapsed;localStorage.setItem(setupStateKey,JSON.stringify(setupState));});});

    const groupDialog=document.querySelector<HTMLDialogElement>('[data-bookmark-dialog]');
    const groupForm=groupDialog?.querySelector<HTMLFormElement>('[data-bookmark-form]');
    const groupOutput=groupDialog?.querySelector<HTMLOutputElement>('[data-bookmark-dialog-output]');
    const groupDelete=groupDialog?.querySelector<HTMLButtonElement>('[data-delete-bookmark-group]');
    let editingGroup:DashboardGroup|null=null;
    const openGroupDialog=(group?:DashboardGroup)=>{if(!groupDialog||!groupForm)return;editingGroup=group||null;groupForm.reset();const name=groupForm.elements.namedItem('name') as HTMLInputElement;name.value=group?.name||'';const color=groupForm.querySelector<HTMLInputElement>(`input[name="color"][value="${CSS.escape(group?.color||'amber')}"]`);if(color)color.checked=true;const icon=groupForm.querySelector<HTMLInputElement>(`input[name="icon"][value="${CSS.escape(group?.icon||'bookmark')}"]`);if(icon)icon.checked=true;const title=groupDialog.querySelector<HTMLElement>('[data-bookmark-dialog-title]');if(title)title.textContent=group?'Edit working set':'New working set';if(groupDelete)groupDelete.hidden=!group;if(groupOutput)groupOutput.textContent='';groupDialog.showModal();window.setTimeout(()=>name.focus(),20);};
    document.querySelectorAll('[data-new-bookmark-group]').forEach((button)=>button.addEventListener('click',()=>openGroupDialog()));
    document.querySelectorAll<HTMLElement>('[data-edit-bookmark-group]').forEach((button)=>button.addEventListener('click',()=>openGroupDialog(readingData.groups.find((group)=>group.id===button.dataset.editBookmarkGroup))));
    groupDialog?.querySelector('[data-bookmark-dialog-close]')?.addEventListener('click',()=>groupDialog.close());
    groupDialog?.querySelector('[data-bookmark-dialog-cancel]')?.addEventListener('click',()=>groupDialog.close());
    groupForm?.addEventListener('submit',(event)=>{event.preventDefault();const values=new FormData(groupForm);const body={name:String(values.get('name')||''),color:String(values.get('color')||'amber'),icon:String(values.get('icon')||'bookmark')};if(groupOutput)groupOutput.textContent='Saving…';void fetch(editingGroup?`/api/bookmark-groups/${editingGroup.id}`:'/api/bookmark-groups',{method:editingGroup?'PATCH':'POST',headers:{'content-type':'application/json'},body:JSON.stringify(body)}).then(async(response)=>{const result=await response.json().catch(()=>({}));if(!response.ok)throw new Error(result.error||'Bookmark group could not be saved.');window.location.reload();}).catch((error)=>{if(groupOutput)groupOutput.textContent=error instanceof Error?error.message:'Bookmark group could not be saved.';});});
    groupDelete?.addEventListener('click',()=>{if(!editingGroup||!confirm(`Delete “${editingGroup.name}”? The items themselves will remain untouched.`))return;groupDelete.disabled=true;void fetch(`/api/bookmark-groups/${editingGroup.id}`,{method:'DELETE'}).then(async(response)=>{if(!response.ok){const result=await response.json().catch(()=>({}));throw new Error(result.error||'Group could not be deleted.');}window.location.reload();}).catch((error)=>{groupDelete.disabled=false;if(groupOutput)groupOutput.textContent=error instanceof Error?error.message:'Group could not be deleted.';});});

    let bookmarkMenu:HTMLElement|null=null;
    const closeBookmarkMenu=()=>{bookmarkMenu?.remove();bookmarkMenu=null;};
    const openBookmarkMenu=(event:MouseEvent,id:string)=>{event.preventDefault();closeBookmarkMenu();const menu=document.createElement('div');menu.className='dashboard-bookmark-menu';const heading=document.createElement('small');heading.textContent='BOOKMARK GROUP';menu.appendChild(heading);if(!readingData.groups.length){const create=document.createElement('button');create.type='button';create.textContent='＋ Create bookmark group…';create.onclick=()=>{closeBookmarkMenu();openGroupDialog();};menu.appendChild(create);}readingData.groups.forEach((group)=>{const assigned=group.itemIds.includes(id);const button=document.createElement('button');button.type='button';button.innerHTML=`<i data-color="${group.color}"></i><span>${assigned?'✓ ':''}${group.name}</span>`;button.onclick=()=>{button.disabled=true;void fetch(`/api/bookmark-groups/${group.id}/items`,{method:'PUT',headers:{'content-type':'application/json'},body:JSON.stringify({referenceIds:[id],enabled:!assigned})}).then(async(response)=>{const result=await response.json().catch(()=>({}));if(!response.ok)throw new Error(result.error||'Bookmark could not be changed.');window.location.reload();}).catch(()=>{button.disabled=false;});};menu.appendChild(button);});document.body.appendChild(menu);const width=menu.offsetWidth,height=menu.offsetHeight;menu.style.left=`${Math.max(8,Math.min(window.innerWidth-width-8,event.clientX))}px`;menu.style.top=`${Math.max(8,Math.min(window.innerHeight-height-8,event.clientY))}px`;bookmarkMenu=menu;};
    document.addEventListener('pointerdown',(event)=>{if(bookmarkMenu&&!bookmarkMenu.contains(event.target as Node))closeBookmarkMenu();});
    document.querySelectorAll<HTMLElement>('[data-dashboard-item]').forEach((item)=>{const id=item.dataset.dashboardItem||'',title=item.dataset.itemTitle||'Reader';item.addEventListener('click',()=>openReader(id,title));item.addEventListener('contextmenu',(event)=>openBookmarkMenu(event,id));let timer=0;item.addEventListener('pointerdown',(event)=>{if(event.pointerType==='mouse')return;timer=window.setTimeout(()=>openBookmarkMenu(new MouseEvent('contextmenu',{clientX:event.clientX,clientY:event.clientY}),id),560);});['pointerup','pointercancel','pointermove'].forEach((name)=>item.addEventListener(name,()=>window.clearTimeout(timer)));});

    const emergenceResult=document.querySelector<HTMLElement>('[data-emergence-result]');
    const renderEmergence=(index:number)=>{const signal=readingData.emergenceSignals[index];if(!signal||!emergenceResult)return;emergenceResult.replaceChildren();const intro=document.createElement('p');intro.innerHTML=`<strong>${signal.phrase}</strong><span>First seen ${signal.firstYear<0?`${Math.abs(signal.firstYear)} BCE`:signal.firstYear}; strongest rise around ${signal.peakYear<0?`${Math.abs(signal.peakYear)} BCE`:signal.peakYear}.</span>`;emergenceResult.appendChild(intro);signal.itemIds.slice(0,6).forEach((id)=>{const item=readingData.emergenceItems[id];if(!item)return;const button=document.createElement('button');button.type='button';button.className='dashboard-reading-item';button.innerHTML=`<span><strong></strong><small>${item.year<0?`${Math.abs(item.year)} BCE`:item.year}</small></span>`;button.querySelector('strong')!.textContent=item.title;button.onclick=()=>openReader(item.id,item.title);emergenceResult.appendChild(button);});document.querySelectorAll<HTMLButtonElement>('[data-emergence-signal]').forEach((button)=>button.setAttribute('aria-pressed',String(Number(button.dataset.emergenceSignal)===index)));};
    document.querySelectorAll<HTMLButtonElement>('[data-emergence-signal]').forEach((button)=>button.addEventListener('click',()=>renderEmergence(Number(button.dataset.emergenceSignal))));
    if(readingData.emergenceSignals.length)renderEmergence(0);

    const yearsTimeline=document.querySelector<HTMLElement>('[data-years-timeline]');
    if(yearsTimeline){
      const panel=yearsTimeline.closest<HTMLElement>('.years-panel')!;
      const svg=yearsTimeline.querySelector<SVGSVGElement>('[data-years-svg]')!;
      const area=svg.querySelector<SVGPolygonElement>('[data-years-area]')!;
      const line=svg.querySelector<SVGPolylineElement>('[data-years-line]')!;
      const grids=[...svg.querySelectorAll<SVGLineElement>('[data-grid-ratio]')];
      const nodes=[...svg.querySelectorAll<SVGGElement>('[data-year-point]')].map((group)=>({group,year:Number(group.dataset.year),count:Number(group.dataset.count),circle:group.querySelector<SVGCircleElement>('circle')!,label:group.querySelector<SVGTextElement>('text')!}));
      const zoomLabel=panel.querySelector<HTMLOutputElement>('[data-years-zoom-label]')!;
      const expandButton=panel.querySelector<HTMLButtonElement>('[data-years-expand]')!;
      const minYear=Math.min(...nodes.map((node)=>node.year));const maxYear=Math.max(...nodes.map((node)=>node.year));const maxCount=Math.max(1,...nodes.map((node)=>node.count));const yearSpan=Math.max(1,maxYear-minYear);
      const padX=42;const padY=32;const defaultZoom=10;let zoom=defaultZoom;let expanded=false;
      const clamp=(value:number,min:number,max:number)=>Math.max(min,Math.min(max,value));
      const niceStep=(minimum:number)=>{const power=10**Math.floor(Math.log10(Math.max(1,minimum)));const fraction=minimum/power;return (fraction<=1?1:fraction<=2?2:fraction<=5?5:10)*power;};
      const renderTimeline=()=>{
        const chartWidth=Math.max(320,Math.round(yearsTimeline.clientWidth*Math.max(1,zoom)));
        const chartHeight=expanded?Math.max(250,Math.round(yearsTimeline.clientHeight)):250;
        const innerWidth=Math.max(1,chartWidth-padX*2);const innerHeight=Math.max(1,chartHeight-padY*2);
        svg.setAttribute('viewBox',`0 0 ${chartWidth} ${chartHeight}`);svg.style.width=`${chartWidth}px`;svg.style.height=`${chartHeight}px`;
        grids.forEach((grid)=>{const ratio=Number(grid.dataset.gridRatio);const y=padY+ratio*innerHeight;grid.setAttribute('x1',String(padX));grid.setAttribute('x2',String(chartWidth-padX));grid.setAttribute('y1',String(y));grid.setAttribute('y2',String(y));});
        const plotted=nodes.map((node)=>{const x=minYear===maxYear?chartWidth/2:padX+((node.year-minYear)/yearSpan)*innerWidth;const y=chartHeight-padY-(node.count/maxCount)*innerHeight;node.circle.setAttribute('cx',String(x));node.circle.setAttribute('cy',String(y));node.label.setAttribute('x',String(x));node.label.setAttribute('y',String(chartHeight-9));return {node,x,y};});
        const points=plotted.map(({x,y})=>`${x},${y}`).join(' ');line.setAttribute('points',points);area.setAttribute('points',plotted.length?`${padX},${chartHeight-padY} ${points} ${plotted.at(-1)!.x},${chartHeight-padY}`:'');
        const pixelsPerYear=innerWidth/yearSpan;const labelStep=niceStep(54/Math.max(.001,pixelsPerYear));
        plotted.forEach(({node})=>{const endpoint=node.year===minYear||node.year===maxYear;node.label.toggleAttribute('hidden',!endpoint&&(node.year-minYear)%labelStep!==0);});
        zoomLabel.value=`${Math.round(zoom*100)}%`;
      };
      const setZoom=(next:number,clientX=yearsTimeline.getBoundingClientRect().left+yearsTimeline.clientWidth/2)=>{
        const rect=yearsTimeline.getBoundingClientRect();const anchor=clamp(clientX-rect.left,0,rect.width);const ratio=(yearsTimeline.scrollLeft+anchor)/Math.max(1,yearsTimeline.scrollWidth);
        zoom=clamp(next,1,20);renderTimeline();yearsTimeline.scrollLeft=ratio*yearsTimeline.scrollWidth-anchor;
      };
      const centerPresent=()=>{const present=clamp(new Date().getFullYear(),minYear,maxYear);const ratio=(present-minYear)/yearSpan;const x=padX+ratio*Math.max(1,yearsTimeline.scrollWidth-padX*2);yearsTimeline.scrollLeft=clamp(x-yearsTimeline.clientWidth/2,0,Math.max(0,yearsTimeline.scrollWidth-yearsTimeline.clientWidth));};
      const resetPresent=()=>{zoom=defaultZoom;renderTimeline();window.requestAnimationFrame(centerPresent);};
      panel.querySelector('[data-years-zoom-out]')?.addEventListener('click',()=>setZoom(zoom/2));
      panel.querySelector('[data-years-zoom-in]')?.addEventListener('click',()=>setZoom(zoom*2));
      panel.querySelector('[data-years-zoom-reset]')?.addEventListener('click',resetPresent);
      expandButton.addEventListener('click',()=>{expanded=!expanded;panel.classList.toggle('is-expanded',expanded);document.body.classList.toggle('years-timeline-expanded',expanded);expandButton.setAttribute('aria-pressed',String(expanded));expandButton.setAttribute('aria-label',expanded?'Collapse timeline':'Expand timeline');window.requestAnimationFrame(renderTimeline);});
      yearsTimeline.addEventListener('wheel',(event)=>{if(!event.ctrlKey&&!event.metaKey)return;event.preventDefault();setZoom(zoom*Math.exp(-event.deltaY*.008),event.clientX);},{passive:false});
      let pinchDistance=0;let pinchZoom=1;
      const touchDistance=(touches:TouchList)=>Math.hypot(touches[0].clientX-touches[1].clientX,touches[0].clientY-touches[1].clientY);
      yearsTimeline.addEventListener('touchstart',(event)=>{if(event.touches.length!==2)return;pinchDistance=touchDistance(event.touches);pinchZoom=zoom;},{passive:true});
      yearsTimeline.addEventListener('touchmove',(event)=>{if(event.touches.length!==2||!pinchDistance)return;event.preventDefault();const center=(event.touches[0].clientX+event.touches[1].clientX)/2;setZoom(pinchZoom*(touchDistance(event.touches)/pinchDistance),center);},{passive:false});
      yearsTimeline.addEventListener('touchend',(event)=>{if(event.touches.length<2)pinchDistance=0;},{passive:true});
      new ResizeObserver(()=>renderTimeline()).observe(yearsTimeline);
      document.addEventListener('keydown',(event)=>{if(event.key==='Escape'&&expanded)expandButton.click();});
      resetPresent();
    }

    const themeSettingsRoot = document.querySelector<HTMLElement>('[data-theme-settings]');
    if (themeSettingsRoot) {
      const choices = [...themeSettingsRoot.querySelectorAll<HTMLButtonElement>('[data-theme-choice]')];
      const currentLabel = themeSettingsRoot.querySelector<HTMLElement>('[data-theme-current]')!;
      const syncThemeChoice = (mode:string,preset:string) => {
        choices.forEach((choice)=>{const active=choice.dataset.themePreset===preset;choice.classList.toggle('is-selected',active);choice.setAttribute('aria-pressed',String(active));});
        const active=choices.find((choice)=>choice.dataset.themePreset===preset);currentLabel.textContent=active?`${active.textContent?.trim()} · ${mode}`:`${preset} · ${mode}`;
      };
      const applyTheme = (mode:string,preset:string) => {
        const root=document.documentElement;
        root.setAttribute('data-theme',mode);root.setAttribute('data-theme-preset',preset);root.classList.toggle('dark-theme',mode==='dark');
        localStorage.setItem('seshat-theme',mode);localStorage.setItem('seshat-theme-preset',preset);localStorage.setItem(`seshat-theme-${mode}-preset`,preset);
        syncThemeChoice(mode,preset);
        window.dispatchEvent(new CustomEvent('seshat:theme-changed',{detail:{theme:mode,preset}}));
      };
      window.addEventListener('seshat:theme-changed',(event)=>{const detail=(event as CustomEvent<{theme?:string;preset?:string}>).detail;if(detail?.theme&&detail?.preset)syncThemeChoice(detail.theme,detail.preset);});
      choices.forEach((choice)=>choice.addEventListener('click',()=>applyTheme(choice.dataset.themeMode||'light',choice.dataset.themePreset||'papyrus')));
      const mode=localStorage.getItem('seshat-theme')||document.documentElement.getAttribute('data-theme')||'light';
      const preset=localStorage.getItem('seshat-theme-preset')||localStorage.getItem(`seshat-theme-${mode}-preset`)||(mode==='dark'?'ink':'papyrus');
      applyTheme(mode,preset);
    }

    const voiceSettingsRoot = document.querySelector<HTMLElement>('[data-voice-settings]');
    if (voiceSettingsRoot && 'speechSynthesis' in window) {
      const key = 'seshat.read-aloud.v1';
      const readSettings = () => { try { return { engine:'native', voice:'', rate:1, nativeVoices:[], ...JSON.parse(localStorage.getItem(key) || '{}') }; } catch { return { engine:'native', voice:'', rate:1, nativeVoices:[] }; } };
      const list = voiceSettingsRoot.querySelector<HTMLElement>('[data-voice-list]')!;
      const search = voiceSettingsRoot.querySelector<HTMLInputElement>('[data-voice-search]')!;
      const summary = voiceSettingsRoot.querySelector<HTMLElement>('[data-voice-summary]')!;
      let voices: SpeechSynthesisVoice[] = [];
      const save = (selected: string[]) => { const settings = readSettings(); localStorage.setItem(key, JSON.stringify({ ...settings, nativeVoices:selected })); };
      const render = () => {
        voices = speechSynthesis.getVoices().sort((a,b) => a.lang.localeCompare(b.lang) || a.name.localeCompare(b.name));
        const settings = readSettings(); const selected = new Set<string>(settings.nativeVoices || []); const query = search.value.trim().toLowerCase();
        list.replaceChildren();
        voices.filter((voice) => !query || `${voice.name} ${voice.lang}`.toLowerCase().includes(query)).forEach((voice) => {
          const label=document.createElement('label'); const checkbox=document.createElement('input'); checkbox.type='checkbox'; checkbox.checked=selected.has(voice.name);
          const text=document.createElement('span'); text.textContent=voice.name; const language=document.createElement('small'); language.textContent=`${voice.lang}${voice.localService?' · local':''}`;
          checkbox.onchange=()=>{checkbox.checked?selected.add(voice.name):selected.delete(voice.name);save([...selected]);summary.textContent=selected.size?`${selected.size} of ${voices.length} shown`:`all ${voices.length} shown`;};
          label.append(checkbox,text,language);list.appendChild(label);
        });
        summary.textContent=selected.size?`${selected.size} of ${voices.length} shown`:`all ${voices.length} shown`;
      };
      search.addEventListener('input',render);
      voiceSettingsRoot.querySelector('[data-microsoft-only]')?.addEventListener('click',()=>{save(voices.filter((voice)=>/Microsoft/i.test(voice.name)).map((voice)=>voice.name));render();});
      voiceSettingsRoot.querySelector('[data-show-all]')?.addEventListener('click',()=>{save([]);render();});
      speechSynthesis.addEventListener('voiceschanged',render); render();
    }
    const chirpVoice = document.querySelector<HTMLSelectElement>('[data-chirp-voice]');
    if (chirpVoice) {
      const key='seshat.read-aloud.v1'; let settings:any={};try{settings=JSON.parse(localStorage.getItem(key)||'{}');}catch{}
      if ([...chirpVoice.options].some((option)=>option.value===settings.voice)) chirpVoice.value=settings.voice;
      chirpVoice.addEventListener('change',()=>{let next:any={};try{next=JSON.parse(localStorage.getItem(key)||'{}');}catch{}localStorage.setItem(key,JSON.stringify({...next,voice:chirpVoice.value}));});
    }

    const zoteroRoot = document.querySelector<HTMLElement>('[data-zotero-settings]');
    if (zoteroRoot) {
      const form=zoteroRoot.querySelector<HTMLFormElement>('[data-zotero-form]')!;
      const output=zoteroRoot.querySelector<HTMLOutputElement>('[data-zotero-output]')!;
      const state=zoteroRoot.querySelector<HTMLElement>('[data-zotero-state]')!;
      const previewButton=zoteroRoot.querySelector<HTMLButtonElement>('[data-zotero-preview]')!;
      const syncButton=zoteroRoot.querySelector<HTMLButtonElement>('[data-zotero-sync]')!;
      const disconnectButton=zoteroRoot.querySelector<HTMLButtonElement>('[data-zotero-disconnect]')!;
      const credentialState=zoteroRoot.querySelector<HTMLElement>('[data-zotero-credential]')!;
      const previewResult=zoteroRoot.querySelector<HTMLElement>('[data-zotero-preview-result]')!;
      let previewVersion=0;
      const busy=(value:boolean)=>{[...form.querySelectorAll<HTMLButtonElement>('button')].forEach((button)=>button.disabled=value);if(!value){previewButton.disabled=zoteroRoot.dataset.connected!=='true';syncButton.disabled=!previewVersion;}};
      form.addEventListener('submit',async(event)=>{
        event.preventDefault();busy(true);output.value='Verifying Zotero permissions…';
        const data=new FormData(form);const body={apiKey:String(data.get('apiKey')||''),syncMode:String(data.get('syncMode')||'bidirectional'),analyzeAutomatically:data.get('analyzeAutomatically')==='on',continuousSync:data.get('continuousSync')==='on',syncIntervalMinutes:Number(data.get('syncIntervalMinutes')||15)};
        const response=await fetch('/api/zotero/connection',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(body)});const result=await response.json().catch(()=>({}));
        if(response.ok){zoteroRoot.dataset.connected='true';state.textContent=`${result.username} · ${result.continuousSync?'continuous sync':'connected'}`;previewButton.disabled=false;disconnectButton.hidden=false;form.querySelector<HTMLInputElement>('[name=apiKey]')!.value='';credentialState.textContent='● key stored encrypted on the server';credentialState.dataset.stored='true';output.value=result.continuousSync?'Connection saved. Continuous synchronization is active.':'Connection saved. Run Preview before synchronizing.';}
        else output.value=result.error||'Zotero connection failed.';busy(false);
      });
      previewButton.addEventListener('click',async()=>{
        busy(true);previewVersion=0;syncButton.disabled=true;output.value='Reading Zotero structure and checking duplicates…';
        const response=await fetch('/api/zotero/preview',{cache:'no-store'});const result=await response.json().catch(()=>({}));
        if(!response.ok){output.value=result.error||'Preview failed.';busy(false);return;}
        previewVersion=Number(result.remote.libraryVersion||0);const changes=result.changes||{};
        previewResult.hidden=false;previewResult.innerHTML=`<article><span>Remote</span><strong>${Number(result.remote.items).toLocaleString()}</strong><small>${Number(result.remote.collections).toLocaleString()} collections · version ${previewVersion}</small></article><article><span>Already mapped</span><strong>${Number(result.local.mapped).toLocaleString()}</strong><small>${Number(result.local.items).toLocaleString()} current Seshat items</small></article><article><span>Safe merges</span><strong>${Number(changes.automaticMerges||0).toLocaleString()}</strong><small>unambiguous identifiers or Inbox → Zotero matches</small></article><article><span>Review candidates</span><strong>${Number(changes.possibleDuplicates||0).toLocaleString()}</strong><small>not merged automatically</small></article><article><span>New items</span><strong>${Number(changes.newItems||0).toLocaleString()}</strong><small>will be created below Zotero/</small></article>`;
        output.value=`Preview ready · ${result.plan.mode} · analysis ${result.plan.analyzeAutomatically?'enabled':'deferred'}.`;busy(false);
      });
      syncButton.addEventListener('click',async()=>{
        if(!previewVersion)return;busy(true);output.value='Synchronizing Zotero. Keep this page open…';
        const response=await fetch('/api/zotero/sync',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify({confirmLibraryVersion:previewVersion})});const result=await response.json().catch(()=>({}));
        if(response.status===409){previewVersion=0;output.value='Zotero changed after the preview. Run Preview again.';busy(false);return;}
        if(!response.ok){output.value=result.error||'Synchronization failed.';busy(false);return;}
        output.value=`Sync complete · pulled ${result.pulled.items} · merged ${result.pulled.merged} · pushed ${result.pushed.items} · ${result.conflicts.length} conflicts.`;previewVersion=0;syncButton.disabled=true;window.setTimeout(()=>location.reload(),1800);
      });
      disconnectButton.addEventListener('click',async()=>{
        if(!confirm('Disconnect Zotero? Mirrored Seshat items and folders will remain.'))return;busy(true);
        const response=await fetch('/api/zotero/connection',{method:'DELETE'});if(response.ok){zoteroRoot.dataset.connected='false';state.textContent='not connected';credentialState.textContent='No key stored';credentialState.dataset.stored='false';disconnectButton.hidden=true;previewVersion=0;output.value='Zotero disconnected. Mirrored data was preserved.';}else output.value='Could not disconnect Zotero.';busy(false);
      });
    }

    // 1. Recover catalog form
    const recoverForm = document.querySelector<HTMLFormElement>('[data-recover-catalog]');
    recoverForm?.addEventListener('submit', async (event) => {
      event.preventDefault(); const button = recoverForm.querySelector<HTMLButtonElement>('button'); const output = recoverForm.querySelector<HTMLOutputElement>('output');
      const previousEmail = String(new FormData(recoverForm).get('previousEmail') || ''); if (!button || !output) return;
      button.disabled = true; output.value = 'Checking previous catalog…';
      const response = await fetch('/api/account/recover', { method:'POST', headers:{'content-type':'application/json'}, body:JSON.stringify({ previousEmail }) });
      const result = await response.json().catch(() => ({}));
      if (response.ok) { output.value = 'Catalog recovered. Reloading…'; location.reload(); return; }
      const labels: Record<string,string> = { catalog_already_linked:'That catalog already belongs to another identity.', duplicate_items_require_review:'Both catalogs contain the same original file; review is required before merging.', library_names_require_review:'Both catalogs contain a library with the same name; rename one before merging.', previous_catalog_not_found:'No previous catalog was found for that email.', stable_identity_required:'Sign out and back in to refresh the stable Authentik identity.' };
      output.value = labels[result.error] || result.error || 'Recovery failed.'; button.disabled = false;
    });

    // 2. Associate secondary email form
    const associateForm = document.querySelector<HTMLFormElement>('[data-associate-email]');
    associateForm?.addEventListener('submit', async (event) => {
      event.preventDefault(); const button = associateForm.querySelector<HTMLButtonElement>('button'); const output = associateForm.querySelector<HTMLOutputElement>('output');
      const secondaryEmail = String(new FormData(associateForm).get('secondaryEmail') || ''); if (!button || !output) return;
      button.disabled = true; output.value = 'Associating login email…';
      const response = await fetch('/api/account/associate', { method:'POST', headers:{'content-type':'application/json'}, body:JSON.stringify({ secondaryEmail }) });
      const result = await response.json().catch(() => ({}));
      if (response.ok) { output.value = 'Email linked successfully. Reloading…'; location.reload(); return; }
      const labels: Record<string,string> = { catalog_already_linked:'That catalog already belongs to another identity.', duplicate_items_require_review:'Both catalogs contain the same original file; review is required before merging.', library_names_require_review:'Both catalogs contain a library with the same name; rename one before merging.', stable_identity_required:'Sign out and back in to refresh login identity.' };
      output.value = labels[result.error] || result.error || 'Link failed.'; button.disabled = false;
    });
  </script>
</Shell>

