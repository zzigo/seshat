<dialog class="dashboard-reader-modal" data-reader-modal>
  <header class="reader-modal-toolbar">
    <div class="reader-modal-scroll">
      <strong data-reader-modal-title title="Reader">Reader</strong>
      <button type="button" class="reader-epub-only reader-modal-initial" data-reader-command="toggle-toc" title="Table of contents" aria-label="Table of contents">C</button>
      <button type="button" class="reader-epub-only reader-chapter-control" data-reader-command="previous-section" title="Previous chapter" aria-label="Previous chapter">‹</button>
      <output class="reader-epub-only reader-modal-chapter" data-reader-modal-chapter title="Current chapter">cap</output>
      <button type="button" class="reader-epub-only reader-chapter-control" data-reader-command="next-section" title="Next chapter" aria-label="Next chapter">›</button>
      <div class="reader-epub-only reader-modal-font" aria-label="Text size">
        <button type="button" data-reader-command="font-smaller" aria-label="Smaller text">A−</button>
        <button type="button" data-reader-command="font-reset" data-reader-modal-font-scale>100%</button>
        <button type="button" data-reader-command="font-larger" aria-label="Larger text">A+</button>
      </div>
      <button type="button" class="reader-modal-initial" data-reader-modal-theme title="Theme" aria-label="Toggle reader and interface theme">T</button>
      <button type="button" class="reader-modal-read reader-modal-initial" data-reader-command="read" data-reader-modal-read title="Read" aria-label="Read">R</button>
      <span class="reader-modal-tail" aria-hidden="true"></span>
      <button type="button" class="reader-epub-only reader-secondary reader-modal-initial" data-reader-command="toggle-flow" data-reader-modal-flow title="Pages">P</button>
      <button type="button" class="reader-page-control reader-secondary" data-reader-command="previous-page" aria-label="Previous page">‹</button>
      <output class="reader-secondary reader-modal-page" data-reader-modal-page>1 / —</output>
      <button type="button" class="reader-page-control reader-secondary" data-reader-command="next-page" aria-label="Next page">›</button>
      <button type="button" class="reader-pdf-only reader-secondary reader-modal-initial" data-reader-command="zoom-reset" title="Fit current page or spread" aria-label="Fit current page or spread">1</button>
      <button type="button" class="reader-pdf-only reader-secondary reader-modal-initial" data-reader-command="toggle-book" title="Book view" aria-label="Book view">B</button>
      <button type="button" class="reader-pdf-only reader-secondary reader-modal-initial" data-reader-command="toggle-grid" title="Grid view" aria-label="Grid view">G</button>
      <button type="button" class="reader-secondary reader-modal-initial" data-reader-command="play-rendered" data-reader-modal-rendered title="Rendered audio" aria-label="Play rendered audio" hidden>A</button>
      <a class="reader-secondary reader-modal-initial" data-reader-modal-original title="Original file" aria-label="Open original file" target="_blank" rel="noreferrer">O</a>
      <button type="button" class="reader-secondary reader-modal-initial" data-reader-modal-fullscreen title="Fullscreen" aria-label="Open reader fullscreen">F</button>
    </div>
    <button type="button" class="reader-modal-close" data-reader-modal-close aria-label="Close reader">×</button>
  </header>
  <iframe data-reader-frame title="Seshat document reader"></iframe>
</dialog>

<script>
  import screenfull from 'screenfull';
  import type { ReaderCommandName, ReaderControlsState } from '../lib/reader-controls';
  import { READER_COMMAND_MESSAGE, READER_STATE_MESSAGE } from '../lib/reader-controls';
  import { normalizeThemeMode, themePresetForMode } from '../lib/theme-preferences';

  const readerModal=document.querySelector<HTMLDialogElement>('[data-reader-modal]');
  const readerFrame=readerModal?.querySelector<HTMLIFrameElement>('[data-reader-frame]');
  const readerModalScroll=readerModal?.querySelector<HTMLElement>('.reader-modal-scroll');
  const readerTitle=readerModal?.querySelector<HTMLElement>('[data-reader-modal-title]');
  const readerThemeButton=readerModal?.querySelector<HTMLButtonElement>('[data-reader-modal-theme]');
  const readerFullscreenButton=readerModal?.querySelector<HTMLButtonElement>('[data-reader-modal-fullscreen]');
  const readerChapter=readerModal?.querySelector<HTMLOutputElement>('[data-reader-modal-chapter]');
  const readerScale=readerModal?.querySelector<HTMLButtonElement>('[data-reader-modal-font-scale]');
  const readerPage=readerModal?.querySelector<HTMLOutputElement>('[data-reader-modal-page]');
  const readerFlow=readerModal?.querySelector<HTMLButtonElement>('[data-reader-modal-flow]');
  const readerRead=readerModal?.querySelector<HTMLButtonElement>('[data-reader-modal-read]');
  const readerRendered=readerModal?.querySelector<HTMLButtonElement>('[data-reader-modal-rendered]');
  const readerOriginal=readerModal?.querySelector<HTMLAnchorElement>('[data-reader-modal-original]');
  let activeReaderId='',readerReady=false,queuedReaderCommand:ReaderCommandName|null=null;
  const applyUnifiedReaderTheme=(modeValue:string)=>{const mode=normalizeThemeMode(modeValue);const preset=themePresetForMode(mode,localStorage.getItem(`seshat-theme-${mode}-preset`)||localStorage.getItem('seshat-theme-preset'));document.documentElement.setAttribute('data-theme',mode);document.documentElement.setAttribute('data-theme-preset',preset);document.documentElement.classList.toggle('dark-theme',mode==='dark');localStorage.setItem('seshat-theme',mode);localStorage.setItem('seshat-theme-preset',preset);localStorage.setItem(`seshat-theme-${mode}-preset`,preset);readerFrame?.contentWindow?.postMessage({type:'seshat:reader-theme',mode,preset},window.location.origin);window.dispatchEvent(new CustomEvent('seshat:theme-changed',{detail:{theme:mode,preset}}));};
  const updateFullscreenControl=()=>{const active=Boolean(screenfull?.isEnabled&&screenfull.isFullscreen);document.documentElement.classList.toggle('reader-native-fullscreen',active&&readerModal?.open===true);if(readerFullscreenButton){readerFullscreenButton.classList.toggle('active',active);readerFullscreenButton.textContent='F';readerFullscreenButton.title=active?'Exit fullscreen':'Fullscreen';readerFullscreenButton.setAttribute('aria-label',active?'Exit reader fullscreen':'Open reader fullscreen');}};
  const closeReader=async()=>{if(screenfull?.isEnabled&&screenfull.isFullscreen)await screenfull.exit().catch(()=>undefined);document.documentElement.classList.remove('reader-native-fullscreen');readerModal?.classList.remove('is-maximized');readerModal?.close();document.documentElement.classList.remove('dashboard-reader-open');readerReady=false;queuedReaderCommand=null;if(readerFrame)readerFrame.src='about:blank';activeReaderId='';updateFullscreenControl();};
  const resetReaderControls=()=>{if(readerChapter)readerChapter.value='cap';if(readerScale)readerScale.textContent='100%';if(readerPage)readerPage.value='1 / —';if(readerFlow){readerFlow.textContent='P';readerFlow.title='Pages';}if(readerRead){readerRead.textContent='R';readerRead.title='Read';readerRead.setAttribute('aria-label','Read');delete readerRead.dataset.readerState;}if(readerRendered)readerRendered.hidden=true;readerModal?.removeAttribute('data-reader-format');};
  const openReader=(id:string,title:string)=>{if(!readerModal||!readerFrame||!id)return;activeReaderId=id;readerReady=false;queuedReaderCommand=null;resetReaderControls();readerModal.classList.add('is-maximized');if(readerModalScroll)readerModalScroll.scrollLeft=0;if(readerTitle){readerTitle.textContent=title;readerTitle.title=title;}if(readerOriginal)readerOriginal.href=`/api/library/${encodeURIComponent(id)}/original`;readerFrame.src=`/dashboard-reader/${encodeURIComponent(id)}`;document.documentElement.classList.add('dashboard-reader-open');readerModal.showModal();updateFullscreenControl();};
  const dispatchReaderCommand=(command:ReaderCommandName)=>readerFrame?.contentWindow?.postMessage({type:READER_COMMAND_MESSAGE,command},window.location.origin);
  const sendReaderCommand=(command:ReaderCommandName)=>{if(!readerReady){queuedReaderCommand=command;if(command==='read'&&readerRead){readerRead.textContent='…';readerRead.title='Reader loading';}return;}dispatchReaderCommand(command);};
  readerModal?.querySelectorAll<HTMLElement>('[data-reader-command]').forEach((control)=>control.addEventListener('click',()=>sendReaderCommand(control.dataset.readerCommand as ReaderCommandName)));
  readerModal?.querySelector('[data-reader-modal-close]')?.addEventListener('click',()=>void closeReader());
  readerThemeButton?.addEventListener('click',()=>applyUnifiedReaderTheme((document.documentElement.getAttribute('data-theme')||'light')==='dark'?'light':'dark'));
  readerFrame?.addEventListener('load',()=>{const mode=document.documentElement.getAttribute('data-theme')||'light';const preset=document.documentElement.getAttribute('data-theme-preset')||(mode==='dark'?'ink':'papyrus');readerFrame.contentWindow?.postMessage({type:'seshat:reader-theme',mode,preset},window.location.origin);});
  window.addEventListener('message',(event)=>{
    if(event.origin!==window.location.origin||event.source!==readerFrame?.contentWindow||event.data?.type!==READER_STATE_MESSAGE)return;
    const state=(event.data.state||{}) as ReaderControlsState;
    if(state.format)readerModal?.setAttribute('data-reader-format',state.format);
    if(readerChapter&&state.chapter){readerChapter.value=state.chapter;readerChapter.title=state.chapter;}
    if(readerScale&&Number.isFinite(state.fontScale))readerScale.textContent=`${Math.round(Number(state.fontScale)*100)}%`;
    if(readerPage&&state.pageLabel){readerPage.value=state.pageLabel;readerPage.title=state.pageLabel;}
    if(readerFlow&&state.flow){const scrolled=state.flow==='scrolled';readerFlow.textContent=scrolled?'S':'P';readerFlow.title=scrolled?'Scroll':'Pages';}
    if(readerRead&&state.readLabel){const readState=state.readState||'idle';const label=readState==='reading'?'Pause':readState==='paused'?'Resume':String(state.readLabel);readerRead.textContent=readState==='reading'?'P':/load|prepar/i.test(label)?'…':'R';readerRead.title=label;readerRead.setAttribute('aria-label',label);readerRead.dataset.readerState=readState;}
    if(readerRendered)readerRendered.hidden=!state.hasRendered;
    if(!readerReady){readerReady=true;const pending=queuedReaderCommand;queuedReaderCommand=null;if(pending)dispatchReaderCommand(pending);}
    if(activeReaderId&&Number.isFinite(state.progress))window.dispatchEvent(new CustomEvent('seshat:reader-progress',{detail:{id:activeReaderId,progress:Number(state.progress)}}));
  });
  readerFullscreenButton?.addEventListener('click',()=>{if(!readerModal||!screenfull?.isEnabled)return;const action=screenfull.isFullscreen?screenfull.exit():screenfull.request(document.documentElement,{navigationUI:'hide'});void action.catch((error)=>console.warn('[seshat:reader-fullscreen]',error));});
  if(screenfull?.isEnabled)screenfull.on('change',updateFullscreenControl);
  readerModal?.addEventListener('dblclick',(event)=>{event.preventDefault();event.stopPropagation();},{capture:true});
  readerModal?.addEventListener('click',(event)=>{if(event.target===readerModal)void closeReader();});
  readerModal?.addEventListener('cancel',(event)=>event.preventDefault());
  window.addEventListener('seshat:open-reader',((event:CustomEvent<{id?:string;title?:string}>)=>openReader(String(event.detail?.id||''),String(event.detail?.title||'Reader'))) as EventListener);
</script>

<style>
  .dashboard-reader-modal{width:min(1500px,calc(100vw - 40px));height:min(920px,calc(100vh - 40px));max-width:none;max-height:none;padding:0;border:1px solid var(--ink);color:var(--ink);background:var(--paper)}
  .dashboard-reader-modal::backdrop{background:rgba(8,12,10,.64);backdrop-filter:blur(3px)}
  .dashboard-reader-modal.is-maximized,.dashboard-reader-modal:fullscreen{position:fixed;inset:0;width:100vw;height:100dvh;max-width:none;max-height:none;margin:0;border:0}.dashboard-reader-modal.is-maximized iframe,.dashboard-reader-modal:fullscreen iframe{height:calc(100dvh - 38px)}
  .reader-modal-toolbar{position:relative;z-index:10;isolation:isolate;height:37px;display:flex;min-width:0;align-items:stretch;overflow:hidden;border-bottom:1px solid var(--ink);background:var(--paper)}
  .reader-modal-scroll{min-width:0;display:flex;flex:1;align-items:center;gap:2px;overflow-x:auto;overflow-y:hidden;padding:0 4px 0 9px;background:var(--paper);scrollbar-width:none;overscroll-behavior-x:contain;-webkit-overflow-scrolling:touch}
  .reader-modal-scroll::-webkit-scrollbar{display:none}.reader-modal-scroll>*{flex:0 0 auto}
  .reader-modal-scroll>strong{width:min(31vw,430px);min-width:70px;overflow:hidden;contain:paint;text-overflow:ellipsis;white-space:nowrap;font:12px ui-monospace,SFMono-Regular,Menlo,monospace}
  .reader-modal-scroll button,.reader-modal-scroll a,.reader-modal-scroll output{height:27px;display:grid;place-items:center;box-sizing:border-box;padding:0 8px;border:0;color:var(--muted);background:var(--paper);font:9.6px/1 ui-monospace,SFMono-Regular,Menlo,monospace;text-decoration:none;white-space:nowrap;cursor:pointer}
  .reader-modal-scroll .reader-modal-initial{min-width:30px;padding-inline:7px;font-size:14.4px}
  .reader-modal-scroll button:hover,.reader-modal-scroll a:hover{color:var(--green)}.reader-modal-scroll button:focus-visible,.reader-modal-close:focus-visible{outline:1px solid var(--gold);outline-offset:-2px}
  .reader-modal-font{display:flex;align-items:center}.reader-modal-font button{min-width:24px;padding:0 5px}.reader-modal-font [data-reader-modal-font-scale]{min-width:36px;padding-inline:2px;color:var(--ink)}
  .reader-chapter-control{min-width:24px!important;padding-inline:4px!important;font-size:18px!important}.reader-modal-chapter{width:min(14vw,190px);min-width:46px;max-width:190px;overflow:hidden;contain:paint;text-overflow:ellipsis}.reader-modal-page{min-width:45px}.reader-modal-read{color:var(--green)!important}.reader-modal-read[data-reader-state="reading"]{box-shadow:inset 0 -2px var(--green)}.reader-modal-read[data-reader-state="paused"]{color:var(--gold)!important}
  .reader-modal-tail{width:1px;height:15px;margin:0 4px;background:var(--hairline)}
  .reader-modal-close{position:relative;z-index:2;width:34px;flex:0 0 34px;display:grid;place-items:center;padding:0;border:0;border-left:1px solid var(--hairline);color:var(--muted);background:var(--paper);font:18px/1 ui-monospace,monospace;cursor:pointer}
  .dashboard-reader-modal:not([data-reader-format]) .reader-epub-only,.dashboard-reader-modal:not([data-reader-format]) .reader-pdf-only,.dashboard-reader-modal:not([data-reader-format]) .reader-page-control,.dashboard-reader-modal:not([data-reader-format]) .reader-modal-page,.dashboard-reader-modal[data-reader-format="pdf"] .reader-epub-only,.dashboard-reader-modal[data-reader-format="epub"] .reader-pdf-only,.dashboard-reader-modal[data-reader-format="text"] .reader-epub-only,.dashboard-reader-modal[data-reader-format="text"] .reader-pdf-only,.dashboard-reader-modal[data-reader-format="text"] .reader-page-control,.dashboard-reader-modal[data-reader-format="text"] .reader-modal-page{display:none}
  .reader-modal-scroll [hidden]{display:none!important}.dashboard-reader-modal iframe{display:block;width:100%;height:calc(100% - 38px);border:0;background:var(--paper)}
  @media(max-width:760px){.dashboard-reader-modal{inset:0;width:100vw;height:100dvh;margin:0;border:0}.reader-modal-toolbar{padding-top:env(safe-area-inset-top);height:calc(39px + env(safe-area-inset-top))}.dashboard-reader-modal iframe{height:calc(100% - 40px - env(safe-area-inset-top))}.reader-modal-scroll>strong{width:min(23vw,150px);min-width:58px}}
  @media(pointer:coarse),(max-width:500px){.reader-page-control{display:none!important}}
  @media(max-width:500px) and (orientation:portrait){:global(html.dashboard-reader-open),:global(html.dashboard-reader-open body){width:100%;max-width:100%;overflow:hidden;overscroll-behavior-x:none}.dashboard-reader-modal{position:fixed;inset:0;inline-size:100%;min-inline-size:0;max-inline-size:100%;block-size:100dvh;min-block-size:0;max-block-size:100dvh;margin:0;padding:0;overflow:hidden;overscroll-behavior:none}.reader-modal-toolbar{width:100%;max-width:100%;min-width:0}.reader-modal-scroll{gap:0;padding-left:5px}.reader-modal-scroll>strong{width:48px;min-width:48px;font-size:9.6px}.reader-modal-scroll button,.reader-modal-scroll a,.reader-modal-scroll output{padding-inline:4px;font-size:8.4px}.reader-modal-scroll .reader-modal-initial{min-width:27px;padding-inline:5px;font-size:12.6px}.reader-chapter-control{min-width:19px!important;padding-inline:2px!important;font-size:17px!important}.reader-modal-chapter{width:31px;min-width:31px;max-width:31px}.reader-modal-font button{min-width:21px;padding-inline:2px}.reader-modal-font [data-reader-modal-font-scale]{min-width:31px}.reader-modal-tail{margin-inline:2px}.reader-modal-close{width:30px;flex-basis:30px}.dashboard-reader-modal iframe{width:100%;max-width:100%;min-width:0;overflow:hidden}}
</style>
