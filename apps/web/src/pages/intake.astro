---
import Shell from '../components/Shell.astro';
import { stagedFilesScript } from '../lib/staged-files';
const batch = Astro.url.searchParams.get('batch') || '';
---

<Shell title="Intake — Seshat">
  <section class="workspace-head">
    <div class="eyebrow">Intake batch</div>
    <h1>A new shelf<br /><em>is taking root.</em></h1>
    <p>Documents enter the processing queue. Bibliographies are separated for inspection and repair.</p>
  </section>
  <section class="intake-board" data-intake data-batch={batch}>
    <div class="intake-summary">
      <span data-total>0 files</span>
      <span data-state>reading local batch…</span>
    </div>
    <div class="intake-list" data-list></div>
  </section>
  <script is:inline set:html={`${stagedFilesScript}
    (() => {
      const board = document.querySelector('[data-intake]');
      const list = board?.querySelector('[data-list]');
      const total = board?.querySelector('[data-total]');
      const state = board?.querySelector('[data-state]');
      const format = (bytes) => bytes < 1048576 ? Math.max(1, Math.round(bytes / 1024)) + ' KB' : (bytes / 1048576).toFixed(1) + ' MB';
      const render = async () => {
        const rows = await readSeshatBatch(board?.dataset.batch || '');
        total.textContent = rows.length + (rows.length === 1 ? ' file' : ' files');
        state.textContent = rows.length ? 'ready to catalogue' : 'no staged files found';
        list.innerHTML = '';
        const upload = async (row, article) => {
          const action = article.querySelector('[data-process]');
          const detail = article.querySelector('small');
          action.disabled = true;
          action.textContent = 'uploading…';
          detail.textContent = format(row.size) + ' · calculating checksum and preserving original';
          const form = new FormData();
          form.append('file', row.file, row.name);
          try {
            const response = await fetch('/api/intake/documents', { method: 'POST', body: form });
            const result = await response.json();
            if (!response.ok) throw new Error(result.error || 'Cataloguing failed.');
            article.classList.add('catalogued');
            detail.textContent = format(row.size) + (result.duplicate ? ' · already in your catalog' : ' · original preserved in Wasabi');
            const link = document.createElement('a');
            link.className = 'route-badge';
            link.href = '/library/' + encodeURIComponent(result.reference.id);
            link.textContent = result.duplicate ? 'open existing' : 'open record';
            action.replaceWith(link);
          } catch (error) {
            action.disabled = false;
            action.textContent = 'retry';
            detail.textContent = error.message;
            article.classList.add('has-error');
          }
        };
        rows.forEach((row) => {
          const bib = row.extension === 'bib';
          const article = document.createElement('article');
          article.className = 'intake-row';
          article.innerHTML = '<span class="file-kind">' + row.extension.toUpperCase() + '</span><div><strong></strong><small></small></div>' + (bib ? '<a class="route-badge">curate</a>' : '<button class="route-badge" data-process>catalogue</button>');
          article.querySelector('strong').textContent = row.name;
          article.querySelector('small').textContent = format(row.size);
          if (bib) {
            const link = article.querySelector('a');
            link.href = '/bibliography/import?batch=' + encodeURIComponent(row.batch);
          } else {
            article.querySelector('[data-process]').addEventListener('click', () => upload(row, article));
          }
          list.appendChild(article);
        });
      };
      render().catch(() => { state.textContent = 'could not read this batch'; });
    })();
  `} />
</Shell>
