---
import { contributorSummary, formatPublicationYear } from '@seshat/core';
import { getCatalog, ownerKeyFor } from '../../lib/catalog';
import { chirpAccessAllowed } from '../../lib/chirp-access';
import { referenceFileType } from '../../lib/reference-file';
import { plainInlineTitle, safeInlineTitleHtml } from '../../lib/inline-title';
import '../../styles/global.css';
import '../../styles/workspace.css';

const email = String((Astro.locals.session as any)?.user?.email || '').trim().toLowerCase();
const reference = email ? await getCatalog().get(ownerKeyFor(email), Astro.params.id || '') : null;
if (!reference) return Astro.redirect('/dashboard?reader=not-found');
const data = {
  id: reference.id,
  title: reference.title,
  format: referenceFileType(reference),
  language: reference.language || '',
  chirpEnabled: chirpAccessAllowed(email),
  hasKokoroNarration: reference.artifacts.some((artifact) => artifact.kind === 'kokoro-audio'),
  hasChirpNarration: reference.artifacts.some((artifact) => artifact.kind === 'chirp-audio'),
};
const pdfLike = ['pdf', 'djvu', 'djv'].includes(data.format);
const serialized = JSON.stringify(data).replace(/</g, '\\u003c');
const propertyYear = Number((reference.issued as Record<string, unknown> | undefined)?.year) || 0;
const propertyPersons = contributorSummary(reference.contributors as Parameters<typeof contributorSummary>[0]);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <title>{plainInlineTitle(reference.title)} — Seshat Reader</title>
  </head>
  <body class="dashboard-reader-body">
    <main class="dashboard-reader document-pod" data-dashboard-reader>
      <header class="pod-toolbar dashboard-reader-toolbar" hidden>
        <strong title={plainInlineTitle(reference.title)} set:html={safeInlineTitleHtml(reference.title)}></strong>
        <div class="dashboard-reader-document-controls">
          <button type="button" data-reader-zoom title="Fit current page or spread">1:1</button>
          {pdfLike && <>
            <button type="button" data-reader-prev aria-label="Previous page">‹</button>
            <span data-reader-page>1 / —</span>
            <button type="button" data-reader-next aria-label="Next page">›</button>
            <button type="button" data-reader-book>Book</button>
            <button type="button" data-reader-grid>Grid</button>
          </>}
        </div>
        <button type="button" class="read-aloud-button" data-reader-read>Read</button>
        <button type="button" class="read-aloud-stop" data-reader-stop hidden>Stop</button>
        {(data.hasKokoroNarration || data.hasChirpNarration) && <button type="button" data-reader-rendered>▶ OGG</button>}
        <a href={`/api/library/${reference.id}/original`} target="_blank" rel="noreferrer">Original ↗</a>
      </header>
      <div class="dashboard-reader-status" data-reader-status>Loading document…</div>
      <section class="pod-document-body" data-reader-surface></section>
      <aside class="dashboard-reader-properties" data-reader-properties hidden>
        <header><strong>Item information</strong><button type="button" data-reader-properties-close aria-label="Close item information">×</button></header>
        <dl>
          <div><dt>Title</dt><dd set:html={safeInlineTitleHtml(reference.title)}></dd></div>
          {propertyPersons && <div><dt>Persons</dt><dd>{propertyPersons}</dd></div>}
          <div><dt>Type</dt><dd>{reference.type}</dd></div>
          {propertyYear !== 0 && <div><dt>Year</dt><dd>{formatPublicationYear(propertyYear)}</dd></div>}
          <div><dt>Citekey</dt><dd>@{reference.citeKey}</dd></div>
          {reference.language && <div><dt>Language</dt><dd>{reference.language}</dd></div>}
          {reference.publisher && <div><dt>Publisher</dt><dd>{reference.publisher}</dd></div>}
          {reference.publisherPlace && <div><dt>Place</dt><dd>{reference.publisherPlace}</dd></div>}
          {reference.tags.length > 0 && <div><dt>Tags</dt><dd>{reference.tags.join(' · ')}</dd></div>}
        </dl>
      </aside>
      <aside class="dashboard-reader-properties dashboard-reader-structure" data-reader-structure hidden>
        <header><strong>Document structure</strong><button type="button" data-reader-structure-close aria-label="Close document structure">×</button></header>
        <div class="dashboard-reader-structure-body" data-reader-structure-body>Loading structure…</div>
      </aside>
      <aside class="dashboard-reader-properties dashboard-reader-annotations" data-reader-annotations hidden>
        <header><strong>Comments and annotations</strong><button type="button" data-reader-annotations-close aria-label="Close comments and annotations">×</button></header>
        <div class="dashboard-reader-annotations-body" data-reader-annotations-body></div>
      </aside>
    </main>
    <script is:inline type="application/json" id="dashboard-reader-data" set:html={serialized}></script>
    <script>
      import { adjacentPdfPage } from '../../lib/pdf-navigation';
      import { mountReaderPageInput } from '../../lib/reader-page-input';
      import { mountReaderSearch } from '../../lib/reader-search';
      import type { ReaderCommandDetail, ReaderControlsState } from '../../lib/reader-controls';
      import { READER_COMMAND_MESSAGE, READER_STATE_MESSAGE } from '../../lib/reader-controls';
      import { normalizeThemeMode, themePresetForMode } from '../../lib/theme-preferences';
      import { mountAnnotationWorkspace } from '../../scripts/annotations';
      import { mountPdfViewer } from '../../scripts/pdf-viewer';
      import { mountEpubReader } from '../../scripts/epub-reader';
      import { mountHtmlReader } from '../../scripts/html-reader';
      import { readAloud } from '../../scripts/read-aloud';

      const theme=normalizeThemeMode(localStorage.getItem('seshat-theme'));
      const preset=themePresetForMode(theme,localStorage.getItem('seshat-theme-preset')||localStorage.getItem(`seshat-theme-${theme}-preset`));
      document.documentElement.setAttribute('data-theme',theme);document.documentElement.setAttribute('data-theme-preset',preset);document.documentElement.classList.toggle('dark-theme',theme==='dark');
      let documentThemeDark=theme==='dark';
      type ReaderData={id:string;title:string;format:string;language:string;chirpEnabled:boolean;hasKokoroNarration:boolean;hasChirpNarration:boolean};
      const data:ReaderData=JSON.parse(document.getElementById('dashboard-reader-data')?.textContent||'{}');
      const pdfLike=['pdf','djvu','djv'].includes(data.format);
      const root=document.querySelector<HTMLElement>('[data-dashboard-reader]')!;
      const surface=root.querySelector<HTMLElement>('[data-reader-surface]')!;
      const status=root.querySelector<HTMLElement>('[data-reader-status]')!;
      const properties=root.querySelector<HTMLElement>('[data-reader-properties]')!;
      const structure=root.querySelector<HTMLElement>('[data-reader-structure]')!;
      const structureBody=root.querySelector<HTMLElement>('[data-reader-structure-body]')!;
      const annotations=root.querySelector<HTMLElement>('[data-reader-annotations]')!;
      const annotationsBody=root.querySelector<HTMLElement>('[data-reader-annotations-body]')!;
      mountReaderSearch(root);
      const closeProperties=()=>{properties.hidden=true;root.querySelector('.pdf-properties-toggle')?.setAttribute('aria-expanded','false');};
      const closeStructure=()=>{structure.hidden=true;root.querySelector('.pdf-structure-toggle')?.setAttribute('aria-expanded','false');};
      const closeAnnotations=()=>{annotations.hidden=true;};
      root.querySelector('[data-reader-properties-close]')?.addEventListener('click',closeProperties);
      root.querySelector('[data-reader-structure-close]')?.addEventListener('click',closeStructure);
      root.querySelector('[data-reader-annotations-close]')?.addEventListener('click',closeAnnotations);
      window.addEventListener('seshat:close-reader-sidebars',((event:CustomEvent<{referenceId?:string}>)=>{if(event.detail?.referenceId&&event.detail.referenceId!==data.id)return;closeProperties();closeStructure();closeAnnotations();}) as EventListener);
      window.addEventListener('seshat:toggle-properties',((event:CustomEvent<{referenceId?:string;open?:boolean}>)=>{if(event.detail?.referenceId&&event.detail.referenceId!==data.id)return;const open=typeof event.detail?.open==='boolean'?event.detail.open:properties.hidden;if(open){closeStructure();closeAnnotations();properties.hidden=false;}else closeProperties();}) as EventListener);
      let structureLoaded=false;
      const naturalStructureText=(value:string)=>{const letters=[...value].filter((character)=>/\p{L}/u.test(character));if(letters.length<2||letters.some((character)=>character!==character.toLocaleUpperCase()))return value;return value.toLocaleLowerCase().replace(/(^|[\s:–—-])\p{L}/gu,(match)=>match.toLocaleUpperCase());};
      const loadStructure=async()=>{if(structureLoaded)return;structureLoaded=true;try{const response=await fetch(`/api/library/${encodeURIComponent(data.id)}/artifact/structure`);if(!response.ok)throw new Error('unavailable');const outline=await response.json() as {sections?:Array<{id:string;level?:number;title?:string;page?:number;kind?:string}>};const list=document.createElement('ol');list.className='dashboard-reader-structure-list';for(const section of (outline.sections||[]).slice(0,1000)){const item=document.createElement('li');item.style.setProperty('--outline-level',String(Math.min(5,Math.max(0,Number(section.level||1)-1))));const button=document.createElement('button');button.type='button';button.disabled=!section.page;const glyph=document.createElement('i');glyph.textContent=section.kind==='references'?'R':section.kind==='appendix'?'A':'§';const title=document.createElement('span');title.textContent=naturalStructureText(section.title||'Untitled section');const page=document.createElement('small');page.textContent=section.page?`p. ${section.page}`:`h${section.level||1}`;button.append(glyph,title,page);button.addEventListener('click',()=>{if(section.page)root.dispatchEvent(new CustomEvent('seshat:pdf-goto-page',{detail:{page:section.page}}));});item.appendChild(button);list.appendChild(item);}structureBody.replaceChildren(list);}catch{structureLoaded=false;structureBody.textContent='Structure is not available yet.';}};
      window.addEventListener('seshat:toggle-structure',((event:CustomEvent<{referenceId?:string;open?:boolean}>)=>{if(event.detail?.referenceId&&event.detail.referenceId!==data.id)return;const open=typeof event.detail?.open==='boolean'?event.detail.open:structure.hidden;if(open){closeProperties();closeAnnotations();structure.hidden=false;void loadStructure();}else closeStructure();}) as EventListener);
      root.addEventListener('dblclick',(event)=>{if(mosaic&&(event.target as HTMLElement).closest('.seshat-pdf-page'))return;event.preventDefault();event.stopPropagation();},{capture:true});
      const report=(message:string,tone:'ready'|'saving'|'error'='ready')=>{status.textContent=message;status.dataset.tone=tone;};
      let annotationsMounted=false;
      const openAnnotations=async(annotationId?:string)=>{
        closeProperties();closeStructure();annotations.hidden=false;
        if(!annotationsMounted){annotationsMounted=true;await mountAnnotationWorkspace(annotationsBody,data.id,data.title,report,{indexOnly:true,initialEditId:annotationId});return;}
        if(annotationId)window.dispatchEvent(new CustomEvent('seshat:edit-annotation',{detail:{referenceId:data.id,annotationId}}));
      };
      window.addEventListener('seshat:request-edit-annotation',((event:CustomEvent<{referenceId?:string;annotationId?:string}>)=>{if(event.detail?.referenceId!==data.id||!event.detail.annotationId)return;void openAnnotations(event.detail.annotationId);}) as EventListener);
      const read=root.querySelector<HTMLButtonElement>('[data-reader-read]')!;
      const stop=root.querySelector<HTMLButtonElement>('[data-reader-stop]')!;
      let controlsState:ReaderControlsState={format:pdfLike?'pdf':data.format==='epub'?'epub':'text',chapter:data.format==='epub'?'cap':'',pageLabel:pdfLike?'1 / —':'',fontScale:1,readLabel:'Read',readState:'idle',hasRendered:data.hasKokoroNarration||data.hasChirpNarration};
      const postState=(partial:Partial<ReaderControlsState>={})=>{controlsState={...controlsState,...partial};window.parent.postMessage({type:READER_STATE_MESSAGE,state:controlsState},window.location.origin);};
      root.addEventListener('seshat:reader-controls',((event:CustomEvent<ReaderControlsState>)=>postState(event.detail||{})) as EventListener);
      readAloud.attach({referenceId:data.id,language:data.language||navigator.language,container:root,button:read,stopButton:stop,report,chirpEnabled:data.chirpEnabled});
      root.querySelector('[data-reader-rendered]')?.addEventListener('click',()=>root.dispatchEvent(new CustomEvent('seshat:play-rendered',{detail:{provider:data.hasKokoroNarration?'kokoro':'chirp'}})));
      root.querySelector('[data-reader-zoom]')?.addEventListener('click',()=>root.dispatchEvent(new CustomEvent('seshat:pdf-zoom-reset')));
      let currentPage=1,totalPages=1,double=false,mosaic=false;
      const page=root.querySelector<HTMLElement>('[data-reader-page]');
      const pageGoto=page?mountReaderPageInput(page,(target)=>root.dispatchEvent(new CustomEvent('seshat:pdf-goto-page',{detail:{page:target,behavior:'auto'}}))):null;
      const movePdf=(delta:-1|1)=>root.dispatchEvent(new CustomEvent('seshat:pdf-goto-page',{detail:{page:adjacentPdfPage(currentPage,delta,totalPages,double&&!mosaic)}}));
      root.addEventListener('seshat:pdf-page-changed',((event:CustomEvent<{page:number;total:number}>)=>{currentPage=event.detail.page;totalPages=event.detail.total||totalPages;const label=`${currentPage} / ${totalPages}`;pageGoto?.update(currentPage,totalPages);postState({pageLabel:label,progress:currentPage/Math.max(1,totalPages)});}) as EventListener);
      root.querySelector('[data-reader-prev]')?.addEventListener('click',()=>movePdf(-1));
      root.querySelector('[data-reader-next]')?.addEventListener('click',()=>movePdf(1));
      const book=root.querySelector<HTMLButtonElement>('[data-reader-book]');const grid=root.querySelector<HTMLButtonElement>('[data-reader-grid]');
      book?.addEventListener('click',()=>{double=!double;if(double&&mosaic){mosaic=false;grid?.classList.remove('active');root.dispatchEvent(new CustomEvent('seshat:pdf-toggle-mosaic',{detail:{active:false}}));}book.classList.toggle('active',double);book.textContent=double?'1 page':'Book';root.dispatchEvent(new CustomEvent('seshat:pdf-toggle-double',{detail:{active:double}}));});
      grid?.addEventListener('click',()=>{mosaic=!mosaic;if(mosaic&&double){double=false;book?.classList.remove('active');if(book)book.textContent='Book';root.dispatchEvent(new CustomEvent('seshat:pdf-toggle-double',{detail:{active:false}}));}grid.classList.toggle('active',mosaic);root.dispatchEvent(new CustomEvent('seshat:pdf-toggle-mosaic',{detail:{active:mosaic}}));});
      root.addEventListener('seshat:pdf-request-mode',((event:CustomEvent<{mode?:string;page?:number}>)=>{if(event.detail.mode==='grid'&&!mosaic)grid?.click();if(event.detail.mode==='page'){if(mosaic)grid?.click();const target=Math.max(1,Math.min(totalPages,Number(event.detail.page||currentPage)));window.requestAnimationFrame(()=>window.requestAnimationFrame(()=>{root.dispatchEvent(new CustomEvent('seshat:pdf-goto-page',{detail:{page:target,behavior:'auto'}}));root.dispatchEvent(new CustomEvent('seshat:pdf-zoom-reset'));}));}}) as EventListener);
      const runCommand=(command:ReaderCommandDetail['command'],detail:ReaderCommandDetail={command})=>{
        if(command==='read-settings'){readAloud.openVoices();return;}
        if(command==='search'){root.dispatchEvent(new CustomEvent('seshat:reader-search-open'));return;}
        if(command==='goto-page'&&pdfLike){root.dispatchEvent(new CustomEvent('seshat:pdf-goto-page',{detail:{page:Math.max(1,Math.min(totalPages,Number(detail.page||currentPage))),behavior:'auto'}}));return;}
        if(command==='read'){read.click();return;}
        if(command==='previous-section'||command==='next-section'){
          const delta=command==='previous-section'?-1:1;
          if(readAloud.state!=='idle')void readAloud.shiftSection(delta);
          else root.dispatchEvent(new CustomEvent<ReaderCommandDetail>('seshat:reader-command',{detail:{command}}));
          return;
        }
        if(command==='previous-page'){if(pdfLike)movePdf(-1);else root.dispatchEvent(new CustomEvent<ReaderCommandDetail>('seshat:reader-command',{detail:{command}}));return;}
        if(command==='next-page'){if(pdfLike)movePdf(1);else root.dispatchEvent(new CustomEvent<ReaderCommandDetail>('seshat:reader-command',{detail:{command}}));return;}
        if(command==='zoom-reset'){root.dispatchEvent(new CustomEvent('seshat:pdf-zoom-reset'));return;}
        if(command==='toggle-book'){book?.click();return;}
        if(command==='toggle-grid'){grid?.click();return;}
        if(command==='play-rendered'){root.dispatchEvent(new CustomEvent('seshat:play-rendered',{detail:{provider:data.hasKokoroNarration?'kokoro':'chirp'}}));return;}
        root.dispatchEvent(new CustomEvent<ReaderCommandDetail>('seshat:reader-command',{detail:{command}}));
      };
      window.addEventListener('message',(event)=>{
        if(event.origin!==window.location.origin||event.source!==window.parent)return;
        if(event.data?.type==='seshat:reader-theme'){const mode=normalizeThemeMode(event.data.mode),nextPreset=themePresetForMode(mode,event.data.preset);documentThemeDark=mode==='dark';document.documentElement.setAttribute('data-theme',mode);document.documentElement.setAttribute('data-theme-preset',nextPreset);document.documentElement.classList.toggle('dark-theme',documentThemeDark);root.dispatchEvent(new CustomEvent('seshat:doc-toggle-invert',{detail:{active:documentThemeDark}}));return;}
        if(event.data?.type===READER_COMMAND_MESSAGE)runCommand(event.data.command as ReaderCommandDetail['command'],event.data as ReaderCommandDetail);
      });
      new MutationObserver(()=>postState({readLabel:read.textContent||'Read',readState:read.dataset.readerState||'idle'})).observe(read,{attributes:true,childList:true,subtree:true,attributeFilter:['data-reader-state']});
      const mount=async()=>{
        void fetch(`/api/library/${encodeURIComponent(data.id)}/reading-state`,{method:'PATCH'});
        if(pdfLike){const isDjVu=['djvu','djv'].includes(data.format);await mountPdfViewer(surface,data.id,data.title,report,isDjVu?`/api/library/${encodeURIComponent(data.id)}/original`:undefined,isDjVu?`/api/library/${encodeURIComponent(data.id)}/artifact/djvu-text`:undefined,isDjVu?'djvu':'pdf');}
        else if(data.format==='epub')await mountEpubReader(surface,data.id,data.title,report);
        else if(data.format==='webarchive')await mountHtmlReader(surface,data.id,data.title,report);
        else{surface.classList.add('pod-reading-surface');const response=await fetch(`/api/library/${encodeURIComponent(data.id)}/artifact/markdown`);if(!response.ok)throw new Error('Extracted text is not available.');const pre=document.createElement('pre');pre.textContent=await response.text();surface.appendChild(pre);}
        root.dispatchEvent(new CustomEvent('seshat:doc-toggle-invert',{detail:{active:documentThemeDark}}));
        report('ready');postState();
      };
      void mount().catch((error)=>report(error instanceof Error?error.message:'Reader unavailable','error'));
    </script>
  </body>
</html>

<style>
  html,body{margin:0;width:100%;height:100%;overflow:hidden;background:var(--paper);color:var(--ink)}
  .dashboard-reader-body{min-width:0}
  .dashboard-reader{position:relative;display:grid;grid-template-rows:minmax(0,1fr);width:100%;height:100%;min-width:0;background:var(--paper)}
  .dashboard-reader-toolbar[hidden]{display:none}
  .dashboard-reader-toolbar{min-width:0;gap:6px;padding:7px 10px;border-bottom:1px solid var(--line)}
  .dashboard-reader-toolbar>strong{min-width:80px;max-width:min(42vw,520px);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:11px;font-weight:500;margin-right:auto}
  .dashboard-reader-toolbar button,.dashboard-reader-toolbar a{min-height:25px;padding:3px 8px;border:1px solid var(--hairline);background:transparent;color:var(--ink);font:9px/1 ui-monospace,monospace;text-decoration:none;cursor:pointer}
  .dashboard-reader-toolbar button.active{border-color:var(--green);color:var(--green)}
  .dashboard-reader-document-controls{display:flex;align-items:center;gap:4px}
  .dashboard-reader-document-controls span{min-width:42px;text-align:center;font:9px/1 ui-monospace,monospace;color:var(--muted)}
  .dashboard-reader-status{position:absolute;width:1px;height:1px;overflow:hidden;clip-path:inset(50%);white-space:nowrap}
  .dashboard-reader-status[data-tone="error"]{z-index:60;top:8px;left:50%;width:auto;height:auto;overflow:visible;clip-path:none;transform:translateX(-50%);padding:5px 8px;color:#a33;background:var(--paper);border:1px solid currentColor;font:9px/1.4 ui-monospace,monospace;white-space:nowrap}
  .pod-document-body{min-height:0;overflow:hidden}
  .pod-reading-surface{overflow:auto;padding:24px}
  .pod-reading-surface pre{max-width:78ch;margin:0 auto;white-space:pre-wrap;font:15px/1.65 ui-serif,serif}
  .dashboard-reader-properties{position:absolute;z-index:2147483000;top:0;right:0;bottom:0;width:min(390px,88vw);overflow:auto;border-left:1px solid var(--hairline);color:var(--ink);background:var(--paper);box-shadow:-10px 0 30px color-mix(in srgb,var(--ink) 20%,transparent)}
  .dashboard-reader-properties[hidden]{display:none}.dashboard-reader-properties>header{position:sticky;top:0;display:flex;align-items:center;justify-content:space-between;min-height:42px;padding-left:13px;border-bottom:1px solid var(--hairline);background:var(--paper);font:9px ui-monospace,monospace;text-transform:uppercase}.dashboard-reader-properties>header button{width:42px;height:42px;border:0;border-left:1px solid var(--hairline);color:var(--ink);background:transparent;font-size:18px;cursor:pointer}.dashboard-reader-properties dl{margin:0}.dashboard-reader-properties dl>div{padding:12px 14px}.dashboard-reader-properties dt{margin-bottom:5px;color:var(--muted);font:7px ui-monospace,monospace;text-transform:uppercase}.dashboard-reader-properties dd{margin:0;overflow-wrap:anywhere;font:13px/1.4 ui-serif,serif}
  .dashboard-reader-structure-body{padding:8px 0}.dashboard-reader-structure-list{margin:0;padding:0;list-style:none}.dashboard-reader-structure-list li{padding-left:calc(var(--outline-level,0) * 12px)}.dashboard-reader-structure-list button{width:100%;display:grid;grid-template-columns:18px minmax(0,1fr) auto;gap:6px;align-items:start;padding:8px 12px;border:0;color:var(--ink);background:transparent;text-align:left;cursor:pointer}.dashboard-reader-structure-list button:hover{color:var(--green);background:color-mix(in srgb,var(--ink) 5%,transparent)}.dashboard-reader-structure-list button:disabled{cursor:default;opacity:.62}.dashboard-reader-structure-list i{font:10px/1.4 ui-monospace,monospace;font-style:normal}.dashboard-reader-structure-list span{font:12px/1.35 ui-serif,serif}.dashboard-reader-structure-list small{color:var(--muted);font:8px/1.5 ui-monospace,monospace;white-space:nowrap}
  .dashboard-reader-annotations{overflow:hidden}.dashboard-reader-annotations-body{height:calc(100% - 42px);min-height:0}.dashboard-reader-annotations-body .annotation-head{display:none}.dashboard-reader-annotations-body .annotation-rail>header{position:static}
  @media(max-width:700px){.dashboard-reader-toolbar{overflow-x:auto;scrollbar-width:none}.dashboard-reader-toolbar>strong{max-width:38vw;flex:0 0 auto}.dashboard-reader-document-controls{flex:0 0 auto}.dashboard-reader-toolbar a{display:none}}
  @media(max-width:500px) and (orientation:portrait){html,body{width:100%;max-width:100%;height:100dvh;overflow:hidden;overscroll-behavior-x:none}.dashboard-reader{width:100%;max-width:100%;min-width:0;margin:0;overflow:hidden}.dashboard-reader-toolbar{width:100%;max-width:100%;overscroll-behavior-x:contain}.pod-document-body{width:100%;max-width:100%;min-width:0}}
</style>
